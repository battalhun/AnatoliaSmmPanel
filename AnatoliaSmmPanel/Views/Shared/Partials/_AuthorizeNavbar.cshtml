            <div class="col">
                <button class="g-dash-btn d-none d-md-block" @* onclick="authMenuToggle(); *@" id="dashBtn">
                    <script>
                                                document.addEventListener("DOMContentLoaded", () => {
                                              const btn = document.getElementById("dashBtn");

                                              if (!btn) return;

                                              btn.addEventListener("click", () => {
                                                authMenuToggle();
                                              });
                                            });

                                                                                                window.authMenuToggle = () => {
                                                                                                const el = document.querySelector(".g-dash");
                                                                                                if (!el) return;
                                                                                                el.classList.toggle("g-bar");
                                                                                            };

   
                    </script>
                    <i class="ri-menu-line"></i>
                    <i class="ri-close-line"></i>
                </button>
            </div>



               


            @* Dil Değiştirme Dropdown *@
            <div class="col-auto ms-auto">
                <div class="btn-group">

                    <button type="button"
                            class="dropdown-toggle language-toggle"
                            data-bs-toggle="dropdown"
                            aria-expanded="false">

                        <div class="colIc">
                            <div class="g-ticon">
                                <i class="ri-earth-line"></i>
                            </div>
                        </div>

                    </button>

                    <ul class="dropdown-menu langs">

                        <li>
                            <a class="dropdown-item" href="?lang=tr">
                                Türkçe
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item" href="?lang=en">
                                English
                            </a>
                        </li>

                        @*  Çoklu Dil Seçeneği Siteye Eklendiği Zaman Aşağıdaki Kod Aktif Edilecek ve Diller Veritabanından Çekilecek *@

                        @*  @if (ViewBag.Languages != null)
                            {
                                foreach (var lang in ViewBag.Languages)
                                {
                                    <li>
                                        <a class="dropdown-item"
                                               href="/@lang.Code">
                                            @lang.Name
                                        </a>
                                    </li>
                                }
                            } *@


                    </ul>

                </div>
            </div>





            @*Admin Panelinde Özelliği Aç-Kapa Olacak ve Para Birimlirini db den Alacak*@

            <div class="col-auto">
                <div class="btn-group">

                    <button type="button"
                            class="currency-toggle currency-drawer-toggle"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                            style="width:auto;">

                        <div class="colIc">
                            <div class="g-ticon">
                                @* {{ user.currency.symbol }} *@
                            </div>
                        </div>

                    </button>

                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item" href="#">USD</a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="#">EUR</a>
                        </li>
                    </ul>

                </div>
            </div>

            

            @* Dropdown menu for profile *@
            <div class="col-auto">
                <div class="btn-group">

                    <button type="button"
                            class="dropdown-toggle profile-toggle"
                            data-bs-toggle="dropdown"
                            aria-expanded="false">

                        <div class="g-genderavatar"
                             style="color: var(--text-color);background: var(--background-1-row);
                            display:flex;justify-content:center;align-items:center;
                            padding:16px;border:2px solid var(--border-color-menu-transparent);
                            border-radius:5px;">

                            <div class="fas fa-cog" style="font-size:23px;"></div>

                        </div>

                    </button>

                    <ul class="dropdown-menu">

                        <li class="d-flex justify-content-between">
                            <span class="dropdown-item col">
                                <i class="fa fa-sun pr-2 me-1"></i> Change mode
                            </span>

                            <div class="colorbox">
                                <button class="btnlight" onclick="change_light()">
                                    <i class="fa fa-sun"></i>
                                </button>
                                <button class="btndark" onclick="change_dark()">
                                    <i class="fas fa-moon"></i>
                                </button>
                            </div>
                        </li>

                        <li><hr class="dropdown-divider"></li>

                        <li><a class="dropdown-item" href="/account">Account</a></li>
                        <li><a class="dropdown-item" href="/terms">Terms</a></li>
                        <li><a class="dropdown-item" href="/faq">FAQ</a></li>
                        <li><a class="dropdown-item" href="/api">API</a></li>

                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                        {
                            <li>
                                <a class="dropdown-item" asp-action="Index" asp-controller="Admin">
                                    Admin Panel
                                </a>
                            </li>
                        }

                        <li><hr class="dropdown-divider"></li>

                        <li>
                            <form id="logoutForm" asp-area="Identity" asp-page="/Account/Logout" method="post">
                                <button type="submit" class="dropdown-item text-danger">
                                    Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>






