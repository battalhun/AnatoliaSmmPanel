@model List<AuthMenuViewModel>
@using AnatoliaSmmPanel.Enums
@using AnatoliaSmmPanel.ViewModels

@{
    // 1. Kullanıcının o an bulunduğu sayfanın Route bilgilerini alıyoruz
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
    var currentPage = ViewContext.RouteData.Values["Page"]?.ToString() ?? "";
    var currentArea = ViewContext.RouteData.Values["Area"]?.ToString() ?? "";
}

@foreach (var menu in Model)
{
    // 2. Her bir menü tipi için eşleşme kontrolü yapıyoruz
    bool isActive = false;

    if (menu.NavigationTarget.MenuConnect == MenuConnect.Mvc)
    {
        isActive = string.Equals(menu.NavigationTarget.Controller, currentController, StringComparison.OrdinalIgnoreCase) &&
                   string.Equals(menu.NavigationTarget.Action, currentAction, StringComparison.OrdinalIgnoreCase);
    }
    else if (menu.NavigationTarget.MenuConnect == MenuConnect.RazorPage)
    {
        isActive = string.Equals(menu.NavigationTarget.Page, currentPage, StringComparison.OrdinalIgnoreCase) &&
                   string.Equals(menu.NavigationTarget.Area, currentArea, StringComparison.OrdinalIgnoreCase);
    }
    else if (menu.NavigationTarget.MenuConnect == MenuConnect.External)
    {
        // Dış linkler (External) genelde sayfa içi aktif menü olarak işaretlenmez
        // Ama istersen buraya mevcut URL ile eşleşme mantığı yazabilirsin.
        isActive = false;
    }

    <li class="g-menu-item">
        @switch (menu.NavigationTarget.MenuConnect)
        {
            case MenuConnect.Mvc:
                <a asp-controller="@menu.NavigationTarget.Controller"
                   asp-action="@menu.NavigationTarget.Action"
                   class="g-menu-link @(isActive ? "active" : "")"
                   target="@(menu.OpenInNewTab ? "_blank" : null)">

                    <span class="g-menu-icon">
                        <i class="@(menu.Icon ?? "ri-dashboard-2-line")"></i>
                    </span>
                    <span class="g-menu-text">@menu.Name</span>

                </a>
                break;

            case MenuConnect.RazorPage:
                <a asp-area="@menu.NavigationTarget.Area"
                   asp-page="@menu.NavigationTarget.Page"
                   class="g-menu-link @(isActive ? "active" : "")"
                   target="@(menu.OpenInNewTab ? "_blank" : null)">
                    <span class="g-menu-icon">
                        <i class="@(menu.Icon ?? "ri-dashboard-2-line")"></i>
                    </span>
                    <span class="g-menu-text">@menu.Name</span>
                </a>
                break;

            case MenuConnect.External:
                <a href="@menu.NavigationTarget.Url"
                   class="g-menu-link @(isActive ? "active" : "")"
                   target="@(menu.OpenInNewTab ? "_blank" : null)">
                    <span class="g-menu-icon">
                        <i class="@(menu.Icon ?? "ri-dashboard-2-line")"></i>
                    </span>
                    <span class="g-menu-text">@menu.Name</span>
                </a>
                break;
        }
    </li>
}