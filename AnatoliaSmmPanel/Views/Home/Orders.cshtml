@model AnatoliaSmmPanel.ViewModels.HomeOrdersPageViewModel
@{
    ViewData["Title"] = "Orders";

    var statusOptions = new (string Key, string Label)[]
    {
        ("all", "All"),
        ("pending", "Pending"),
        ("inprogress", "In Progress"),
        ("completed", "Completed"),
        ("partial", "Partial"),
        ("processing", "Processing"),
        ("canceled", "Canceled"),
    };

    string StatusCssClass(string status) => status switch
    {
        "Completed" => "completed",
        "Processing" => "processing",
        "Pending" => "pending",
        "Partial" => "partial",
        "In progress" => "inprogress",
        "Canceled" => "cancelled",
        _ => ""
    };
}

<div class="g-dash-content">

    <section class="pt-4">
        <div class="container-fluid">
            <div class="gcard gcard-border">
                <div class="gcard-body p-3">
                    <div class="row align-items-center">
                        <div class="col-md-auto col-12">
                            <div class="dropdown">
                                <button class="btn btn-primary btn-sm btn-100 dropdown-toggle gny-btn" type="button" id="filterServicesDd" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="fas fa-filter"></span>
                                    <span data-filter-active-category="true">
                                        @(statusOptions.FirstOrDefault(s => s.Key == Model.Status).Label ?? "Filters")
                                    </span>
                                    <span class="fas fa-caret-down" style="text-overflow: clip;"></span>
                                </button>
                                <ul class="dropdown-menu" aria-labelledby="filterServicesDd">
                                    @foreach (var opt in statusOptions)
                                    {
                                        <li>
                                            <a class="dropdown-item @(Model.Status == opt.Key ? "active" : "")"
                                               href="@Url.Action("Orders", "Home", new { status = opt.Key })">
                                                @opt.Label
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                        <div class="col-lg">
                            <form action="@Url.Action("Orders", "Home", new { status = Model.Status })" method="get" id="history-search">
                                <div class="g-search">
                                    <button type="submit" class="g-ticon" style="background: none; border: none; outline: 0">
                                        <i class="ri-search-line"></i>
                                    </button>
                                    <input type="text" name="search" class="textbox" value="@Model.Search" placeholder="Search by order ID, link or service...">
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="pt-4">
        <div class="container-fluid">
            <div class="order-container">

                @if (!Model.Orders.Any() && Model.Status == "all" && string.IsNullOrEmpty(Model.Search))
                {
                    <div class="gcard-2 gcard-shadow fade-3 mt-3 p-3">
                        <div class="gcard-body">
                            <div class="noorders text-center">
                                <p>Hello, you have not placed an order before.</p>
                                <p>You can place your first order from the <a href="/new-order">new order</a> page.<br>After placing your first order, you can learn the status of your orders from this page.</p>
                                <div class="d-flex justify-content-center mt-5">
                                    <a href="/new-order"><button class="btn btn-primary mb-4 mx-1">Place an Order</button></a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else if (!Model.Orders.Any())
                {
                    <div class="gcard-2 gcard-shadow fade-3 mt-3 p-3">
                        <div class="gcard-body text-center text-body-secondary py-4">
                            <i class="fas fa-search fa-2x mb-3 opacity-50"></i>
                            <p class="mb-0">No orders match your filter.</p>
                        </div>
                    </div>
                }

                @foreach (var order in Model.Orders)
                {
                    <div class="gcard mb-3">
                        <div class="gcard-body">
                            <div class="orderCardtop cursor-pointer">
                                <div class="row align-items-center">

                                    <div class="col-lg-auto col-md-auto mb-3 mb-lg-0">
                                        <div onclick="copyToClipboard('@order.Id')" class="g-status os-sm completed d-flex align-items-center">
                                            <span>#@order.Id</span>
                                            <i class="ri-file-copy-line cursor-pointer pl-2"></i>
                                        </div>
                                    </div>

                                    <div class="col-lg-6 col-md mb-3 mb-lg-0">
                                        <h3 class="g-order-title">
                                            @order.ServiceId - @order.ServiceName
                                        </h3>
                                        <div class="d-flex g-olink mb-0">
                                            <a class="link" href="@order.Link" target="_blank" rel="noopener noreferrer">
                                                @order.Link
                                                <i class="fal fa-external-link"></i>
                                            </a>
                                        </div>
                                        <i class="ri-file-copy-line linkcopy cursor-pointer pl-2" onclick="copyToClipboard('@order.Link')"> Copy Link</i>
                                    </div>

                                    <div class="col-12 d-none d-md-block d-lg-none"></div>

                                    <div class="col-lg col-md-6 mb-3 mb-lg-0">
                                        <div class="g-order-date">@order.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                                    </div>

                                    <div class="col-lg-auto">
                                        <div class="g-status @StatusCssClass(order.Status)">
                                            @order.Status
                                        </div>
                                        @if (!string.IsNullOrEmpty(order.CancelReason))
                                        {
                                            <button type="button" class="btn mt-3 btn-primary g-status" data-bs-toggle="modal" data-bs-target="#cancelReasonModal@(order.Id)" style="white-space: nowrap;">Cancel Detail</button>
                                        }
                                    </div>

                                    <div class="col-lg-auto">
                                        <button class="btn btn-primary dropdown-toggle" type="button" id="openOrder@(order.Id)">
                                            <span class="fas fa-angle-down active" id="down@(order.Id)"></span>
                                            <span class="fas fa-angle-up" id="up@(order.Id)"></span>
                                        </button>
                                    </div>

                                </div>
                            </div>

                            <div class="g-order-bottom hidden" id="thisOrder@(order.Id)">
                                <div class="row align-items-center row-cols-md-4 row-cols-2">

                                    <div class="col-lg-auto mt-3 mt-md-0">
                                        <div class="g-order-item">
                                            <div class="title">Charge</div>
                                            <div class="text">$@order.Charge.ToString("0.0000")</div>
                                        </div>
                                    </div>

                                    <div class="col-lg-auto mt-3 mt-md-0">
                                        <div class="g-order-item">
                                            <div class="title">Start Count</div>
                                            <div class="text">@order.StartCount</div>
                                        </div>
                                    </div>

                                    <div class="col-lg-auto mt-3 mt-md-0">
                                        <div class="g-order-item">
                                            <div class="title">Quantity</div>
                                            <div class="text">@order.Quantity</div>
                                        </div>
                                    </div>

                                    <div class="col-lg-auto mt-3 mt-md-0">
                                        <div class="g-order-item">
                                            <div class="title">Remains</div>
                                            <div class="text">@order.Remains</div>
                                        </div>
                                    </div>

                                    <div class="col-lg-auto col-12 col-md-12 ms-lg-auto d-flex align-items-center justify-content-center mt-3 mt-lg-0 ms-auto">
                                        <span class="order-actions">
                                            @if (order.RefillAvailable)
                                            {
                                                <button class="btn btn-success btn-md me-1" onclick="requestRefill(@order.Id)">
                                                    <i class="ri-restart-line me-2"></i><span>Refill</span>
                                                </button>
                                            }
                                            @if (order.CancelAvailable)
                                            {
                                                <button class="btn btn-danger btn-md me-1" onclick="cancelOrder(@order.Id)">Cancel</button>
                                            }
                                        </span>
                                        <a onclick="openOrderSupport(@order.Id, '@order.Status')" class="btn btn-primary btn-md cursor-pointer">
                                            <i class="ri-customer-service-2-line"></i>
                                        </a>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(order.CancelReason))
                    {
                        <div class="modal fade" id="cancelReasonModal@(order.Id)" tabindex="-1" aria-labelledby="cancelReasonModalLabel@(order.Id)" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="cancelReasonModalLabel@(order.Id)">Reason for Cancellation</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        @order.CancelReason
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <script>
                                        document.getElementById('openOrder@(order.Id)').addEventListener('click', function () {
                                            document.getElementById('thisOrder@(order.Id)').classList.toggle('hidden');
                                            document.getElementById('down@(order.Id)').classList.toggle('active');
                                            document.getElementById('up@(order.Id)').classList.toggle('active');
                                        });
                    </script>
                }

            </div>

            <!-- PAGINATION -->
            @if (Model.TotalPages > 1)
            {
                <section class="mt-3">
                    <div class="container text-center d-flex justify-content-center">
                        <nav aria-label="Order pages">
                            <ul class="pagination">

                                @if (Model.CurrentPage > 1)
                                {
                                    <li class="page-item pi-pn">
                                        <a class="page-link" href="@Url.Action("Orders", "Home", new { status = Model.Status, page = Model.CurrentPage - 1, search = Model.Search })" aria-label="Previous">
                                            <i class="ri-arrow-left-s-line"></i>
                                        </a>
                                    </li>
                                }

                                @{
                                    var startPage = Math.Max(1, Model.CurrentPage - 3);
                                    var endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 3);
                                }

                                @for (var i = startPage; i <= endPage; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Orders", "Home", new { status = Model.Status, page = i, search = Model.Search })">@i</a>
                                    </li>
                                }

                                @if (Model.CurrentPage < Model.TotalPages)
                                {
                                    <li class="page-item pi-pn">
                                        <a class="page-link" href="@Url.Action("Orders", "Home", new { status = Model.Status, page = Model.CurrentPage + 1, search = Model.Search })" aria-label="Next">
                                            <span aria-hidden="true">&raquo;</span>
                                        </a>
                                    </li>
                                }

                            </ul>
                        </nav>
                    </div>
                </section>
            }

        </div>
    </section>

</div>

<!-- CANCEL CONFIRM MODAL -->
<div class="modal fade" id="orderCancelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title">Cancel Order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Are you sure you want to cancel this order? This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-link text-secondary" data-bs-dismiss="modal">No, keep it</button>
                <button type="button" class="btn btn-danger px-4" id="orderCancelConfirmBtn">Yes, cancel</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>

        function copyToClipboard(text) {
            navigator.clipboard.writeText(text);
        }

        // ── Cancel Order ───────────────────────────────────────────
        let pendingCancelOrderId = null;

        function cancelOrder(orderId) {
            pendingCancelOrderId = orderId;
            new bootstrap.Modal(document.getElementById('orderCancelModal')).show();
        }

        document.getElementById('orderCancelConfirmBtn').addEventListener('click', async function () {
            if (!pendingCancelOrderId) return;

            const btn = this;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Canceling...';

            try {
                const token = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') ?? '';

                const res = await fetch('/home/orders/cancel', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token },
                    body: JSON.stringify({ orderId: pendingCancelOrderId })
                });

                const result = await res.json();

                if (result.success) {
                    window.location.reload();
                } else {
                    alert(result.message || 'Failed to cancel order.');
                }
            } catch (err) {
                alert('Connection error.');
                console.error(err);
            } finally {
                btn.disabled = false;
                btn.textContent = 'Yes, cancel';
                bootstrap.Modal.getInstance(document.getElementById('orderCancelModal'))?.hide();
            }
        });

        // ── Refill (placeholder - backend endpoint eklenmeli) ──────
        function requestRefill(orderId) {
            alert('Refill request for order #' + orderId + ' — backend endpoint not implemented yet.');
        }

        // ── Order support / open ticket from order ─────────────────
        function openOrderSupport(orderId, status) {
            window.location.href = `/tickets?order=${orderId}&status=${encodeURIComponent(status)}`;
        }

    </script>
}
