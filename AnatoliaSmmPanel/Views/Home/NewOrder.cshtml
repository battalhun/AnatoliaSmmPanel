@{
    ViewData["Title"] = "New Order";
    var balance = ViewData["Balance"] as decimal? ?? 0m;
    var spent = ViewData["Spent"] as decimal? ?? 0m;
}

<div class="g-dash-content">

    <!-- ── Bakiye Kartları ───────────────────────────────── -->
    <section class="mt-4 mb-2">
        <div class="container-fluid">
            <div class="row mb-5">
                <div class="col-lg-7">
                    <div class="row">
                        <div class="col-lg-6">
                            <div class="gcard-2 gcard-shadow fade-2">
                                <div class="gcardc">
                                    <div class="row align-items-center">
                                        <div class="col">
                                            <h2>Balance</h2>
                                            <h3>$@balance.ToString("0.0000")</h3>
                                        </div>
                                        <div class="col-auto">
                                            <div class="gny-circle">
                                                <i class="ri-wallet-3-line"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6 d-none d-md-block">
                            <div class="gcard-2 gcard-shadow fade-4">
                                <div class="gcardc">
                                    <div class="row align-items-center">
                                        <div class="col">
                                            <h2>Spent</h2>
                                            <h3>$@spent.ToString("0.0000")</h3>
                                        </div>
                                        <div class="col-auto">
                                            <div class="gny-circle">
                                                <i class="ri-line-chart-line"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── Ana İçerik ────────────────────────────────────── -->
    <section class="nwoMain mt-3">
        <div class="container-fluid">

            <!-- Kategori Swiper -->
            <div id="new-order-cats" class="swiper nwo-categories">
                <div class="swiper-wrapper" id="categorySwiperWrapper">
                    <div class="swiper-slide">
                        <button class="nwo-cat-btn active" data-cat-id="" data-cat-name="All">
                            <span class="g-ticon"><i class="fal fa-stream" style="display:block!important;"></i></span>
                            <span class="text" style="font-size:13px!important;left:auto!important;position:static;">All</span>
                        </button>
                    </div>
                    <!-- JS ile doldurulacak -->
                </div>
                <div class="swiper-button-prev"></div>
                <div class="swiper-button-next"></div>
            </div>

            <div class="row mt-3">

                <!-- ── Sipariş Formu ──────────────────────────── -->
                <div class="col-lg-7 mb-4 mb-lg-0">
                    <div class="gcard">
                        <div class="gcard-header">
                            <div class="row align-items-center">
                                <div class="col d-flex align-items-center">
                                    <div class="ch-g-ticon">
                                        <div class="gcard-head-icon">
                                            <i class="ri-dashboard-2-line"></i>
                                        </div>
                                    </div>
                                    <div class="ch-text">
                                        <h3 class="gcard-title">Create an order</h3>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="gcard-body">
                            <div class="gnyNeworder">

                                <!-- Alert -->
                                <div id="orderAlert"></div>

                                <!-- Search -->
                                <div class="form-group mb-4">
                                    <div class="input-wrapper" style="position:relative;">
                                        <button style="position:absolute;top:50%;transform:translateY(-50%);padding:0 2px;background:none;border:none;left:12px;" type="button">
                                            <span class="fas fa-search"></span>
                                        </button>
                                        <input type="text" class="form-control ps-5" id="serviceSearch" placeholder="Search services...">
                                    </div>
                                </div>

                                <!-- Category -->
                                <div class="form-group mb-4">
                                    <label class="control-label">Category</label>
                                    <select class="form-control" id="orderform-category">
                                        <option value="">All Categories</option>
                                        <!-- JS ile doldurulacak -->
                                    </select>
                                </div>

                                <!-- Service -->
                                <div class="form-group mb-4">
                                    <label class="control-label">Service</label>
                                    <select class="form-control" id="orderform-service">
                                        <option value="">— Select a service —</option>
                                    </select>
                                </div>

                                <!-- Description -->
                                <div class="form-group mb-4 d-none" id="service_description">
                                    <label class="control-label">Description</label>
                                    <div class="panel-body border rounded p-3" style="line-height:24px;" id="gnySdesc"></div>
                                </div>

                                <!-- Dynamic fields (link / quantity / etc.) -->
                                <div id="fields"></div>

                                <!-- Charge -->
                                <div class="form-group mb-4">
                                    <label class="control-label">Charge</label>
                                    <input type="text" class="form-control" id="charge" value="" readonly placeholder="—">
                                </div>

                                <!-- Submit -->
                                <button type="button" id="btnPlaceOrder" class="btn btn-primary btn-block w-100">
                                    <span id="btnPlaceOrderText"><i class="fas fa-paper-plane me-2"></i>Place Order</span>
                                    <span id="btnPlaceOrderSpinner" class="d-none">
                                        <span class="spinner-border spinner-border-sm me-2"></span>Processing...
                                    </span>
                                </button>

                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── Duyurular ──────────────────────────────── -->
                <div class="col-lg-5">
                    <div class="gcard">
                        <div class="gcard-header">
                            <div class="row align-items-center">
                                <div class="col d-flex align-items-center">
                                    <div class="ch-g-ticon">
                                        <div class="gcard-head-icon">
                                            <i class="ri-pushpin-2-line"></i>
                                        </div>
                                    </div>
                                    <div class="ch-text">
                                        <h3 class="gcard-title">Announcements</h3>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="gcard-body news-item" style="max-height:500px;overflow-y:scroll;">

                            <div class="gcard-2 gcard-shadow fade-1">
                                <div class="row align-items-center">
                                    <div class="col-auto">
                                        <div class="news-icon news-bg1"><i class="far fa-bullhorn"></i></div>
                                    </div>
                                    <div class="col">
                                        <div class="news-text">
                                            <h6 class="service">Important Announcement Regarding Access Issues</h6>
                                            <p class="desc">
                                                Dear Valued Customers,<br><br>
                                                We would like to sincerely apologize for the recent inconvenience you may have experienced while trying to access our SMM panel.<br><br>
                                                The domain provider we were using was unfortunately subjected to a cyberattack. We want to assure you that this attack was not targeted at our company specifically, and there has been no breach of your personal data or any security-related issue on our side.<br><br>
                                                Thank you for being with us.<br><br>Warm regards,<br>ANATOLIA SMM TEAM
                                            </p>
                                            <span class="time"><i class="fas fa-history pr-2"></i>20.05.2025</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="gcard-2 gcard-shadow fade-1">
                                <div class="row align-items-center">
                                    <div class="col-auto">
                                        <div class="news-icon news-bg1"><i class="far fa-bullhorn"></i></div>
                                    </div>
                                    <div class="col">
                                        <div class="news-text">
                                            <h6 class="service">Important Update: Instagram Followers Services</h6>
                                            <p class="desc">
                                                Due to the recent Instagram update, many follower services have been disrupted. We have created a new category, "Instagram Followers | Working Services," which we are continuously updating.<br><br>
                                                👉 Turn off the "Flag for Review" button before ordering.
                                            </p>
                                            <span class="time"><i class="fas fa-history pr-2"></i>18.08.2024</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="gcard-2 gcard-shadow fade-1">
                                <div class="row align-items-center">
                                    <div class="col-auto">
                                        <div class="news-icon news-bg1"><i class="far fa-bullhorn"></i></div>
                                    </div>
                                    <div class="col">
                                        <div class="news-text">
                                            <h6 class="service">New Services Added</h6>
                                            <p class="desc">We have added new services to our panel. Check the services page for details.</p>
                                            <span class="time"><i class="fas fa-history pr-2"></i>15.06.2024</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

</div>

@section Scripts {
    <script>
        // ── Veriler ──────────────────────────────────────────────
        let allServices = [];       // DB'den yüklenen tüm aktif servisler
        let allCategories = [];     // Kategori listesi
        let selectedService = null; // Seçili servis objesi

        const categoryIcons = {
            'Instagram':     'fab fa-instagram',
            'Twitter':       'fab fa-twitter',
            'TikTok':        'fab fa-tiktok',
            'Youtube':       'fab fa-youtube',
            'Facebook':      'fab fa-facebook-f',
            'Telegram':      'fab fa-telegram-plane',
            'Twitch':        'fab fa-twitch',
            'Discord':       'fab fa-discord',
            'Linkedin':      'fab fa-linkedin',
            'SoundCloud':    'fab fa-soundcloud',
            'Spotify':       'fab fa-spotify',
            'Vk':            'fab fa-vk',
            'Snapchat':      'fab fa-snapchat-ghost',
            'Tumblr':        'fab fa-tumblr',
            'Vimeo':         'fab fa-vimeo',
            'Reddit':        'fab fa-reddit-square',
            'Whatsapp':      'fab fa-whatsapp-square',
            'Deezer':        'fab fa-deezer',
            'Odnoklassniki': 'fab fa-odnoklassniki',
            'Google':        'fab fa-google',
            'Pinterest':     'fab fa-pinterest',
            'Quora':         'fab fa-quora',
            'Foursquare':    'fab fa-foursquare',
        };

        // ── Servisleri DB'den Yükle ───────────────────────────────
        async function loadServices() {
            try {
                const res  = await fetch('/home/GetServices');
                const data = await res.json();
                if (!data.success) return;

                allServices   = data.services;
                allCategories = data.categories;

                buildCategorySwiper(allCategories);
                buildCategoryDropdown(allCategories);
                buildServiceDropdown(allServices);

            } catch (e) {
                console.error('Failed to load services:', e);
            }
        }

        // ── Kategori Swiper'ı Oluştur ─────────────────────────────
        function buildCategorySwiper(categories) {
            const wrapper = document.getElementById('categorySwiperWrapper');
            // Sadece dinamik slide'ları temizle (ilk "All" slide kalıcı)
            while (wrapper.children.length > 1) wrapper.removeChild(wrapper.lastChild);

            categories.forEach(cat => {
                const icon = categoryIcons[cat.name] || 'fab fa-globe';
                const slide = document.createElement('div');
                slide.className = 'swiper-slide';
                slide.innerHTML = `
                    <button class="nwo-cat-btn" data-cat-id="${cat.id}" data-cat-name="${cat.name}">
                        <span class="g-ticon"><i class="${icon}"></i></span>
                        <span class="text">${cat.name}</span>
                    </button>`;
                wrapper.appendChild(slide);
            });

            // Swiper yeniden başlat
            if (window.categorySwiper) {
                window.categorySwiper.destroy(true, true);
            }
            window.categorySwiper = new Swiper('#new-order-cats', {
                slidesPerView: 'auto',
                spaceBetween: 8,
                navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' }
            });
        }

        // ── Kategori Dropdown'ı Oluştur ───────────────────────────
        function buildCategoryDropdown(categories) {
            const select = document.getElementById('orderform-category');
            // İlk option korunuyor ("All Categories")
            while (select.options.length > 1) select.remove(1);

            categories.forEach(cat => {
                const opt = document.createElement('option');
                opt.value = cat.id;
                opt.text  = cat.name;
                select.add(opt);
            });
        }

        // ── Servis Dropdown'ı Filtrele & Doldur ───────────────────
        function buildServiceDropdown(services) {
            const select = document.getElementById('orderform-service');
            select.innerHTML = '<option value="">— Select a service —</option>';

            services.forEach(s => {
                const opt = document.createElement('option');
                opt.value      = s.id;
                opt.text       = `[${s.id}] ${s.name}`;
                opt.dataset.min  = s.minOrder;
                opt.dataset.max  = s.maxOrder;
                opt.dataset.rate = s.rate;
                opt.dataset.desc = s.description ?? '';
                opt.dataset.type = s.type ?? 'Default';
                select.add(opt);
            });

            selectedService = null;
            resetForm();
        }

        // ── Form Alanlarını Sıfırla ───────────────────────────────
        function resetForm() {
            document.getElementById('fields').innerHTML = '';
            document.getElementById('charge').value    = '';
            document.getElementById('gnySdesc').innerHTML = '';
            document.getElementById('service_description').classList.add('d-none');
        }

        // ── Servis Seçildi ─────────────────────────────────────────
        function onServiceSelected(serviceId) {
            if (!serviceId) { selectedService = null; resetForm(); return; }

            const s = allServices.find(x => x.id == serviceId);
            if (!s) return;
            selectedService = s;

            // Description
            if (s.description) {
                document.getElementById('gnySdesc').innerHTML = s.description;
                document.getElementById('service_description').classList.remove('d-none');
            } else {
                document.getElementById('gnySdesc').innerHTML = '';
                document.getElementById('service_description').classList.add('d-none');
            }

            // Dynamic fields
            renderFields(s);
            calculateCharge();
        }

        // ── Dinamik Alanları Render Et ────────────────────────────
        function renderFields(s) {
            const container = document.getElementById('fields');
            container.innerHTML = '';

            // Link alanı (her servis türünde var)
            container.innerHTML += `
                <div class="form-group mb-4">
                    <label class="control-label">Link / Username</label>
                    <input type="text" class="form-control" id="orderLink" placeholder="https://...">
                </div>`;

            // Quantity alanı
            container.innerHTML += `
                <div class="form-group mb-4">
                    <label class="control-label">Quantity
                        <span class="text-muted small">(Min: ${s.minOrder} — Max: ${s.maxOrder})</span>
                    </label>
                    <input type="number" class="form-control" id="orderQuantity"
                        min="${s.minOrder}" max="${s.maxOrder}" value="${s.minOrder}">
                </div>`;

            // Dripfeed alanları (eğer destekliyorsa)
            if (s.dripfeed) {
                container.innerHTML += `
                    <div class="form-group mb-4">
                        <label class="control-label">Runs <span class="text-muted small">(Dripfeed)</span></label>
                        <input type="number" class="form-control" id="orderRuns" min="1" value="1">
                    </div>
                    <div class="form-group mb-4">
                        <label class="control-label">Interval (minutes)</label>
                        <input type="number" class="form-control" id="orderInterval" min="1" value="60">
                    </div>`;
            }

            // Quantity değişince charge hesapla
            document.getElementById('orderQuantity')?.addEventListener('input', calculateCharge);
        }

        // ── Charge Hesapla ────────────────────────────────────────
        function calculateCharge() {
            if (!selectedService) return;

            const qty    = parseInt(document.getElementById('orderQuantity')?.value || 0);
            const rate   = parseFloat(selectedService.rate);
            const charge = (qty * rate) / 1000;

            document.getElementById('charge').value = '$' + charge.toFixed(4);
        }

        // ── Sipariş Ver ───────────────────────────────────────────
        document.addEventListener('click', async function (e) {
            if (e.target.id !== 'btnPlaceOrder' && !e.target.closest('#btnPlaceOrder')) return;

            const userId = document.querySelector('meta[name="current-user-id"]')?.getAttribute('content');
            const alertBox = document.getElementById('orderAlert');
            alertBox.innerHTML = '';

            if (!selectedService) {
                alertBox.innerHTML = `<div class="alert alert-danger mb-3">Please select a service.</div>`;
                return;
            }

            const link = document.getElementById('orderLink')?.value.trim();
            const qty  = parseInt(document.getElementById('orderQuantity')?.value || 0);

            if (!link) {
                alertBox.innerHTML = `<div class="alert alert-danger mb-3">Please enter a link or username.</div>`;
                return;
            }

            if (qty < selectedService.minOrder || qty > selectedService.maxOrder) {
                alertBox.innerHTML = `<div class="alert alert-danger mb-3">Quantity must be between ${selectedService.minOrder} and ${selectedService.maxOrder}.</div>`;
                return;
            }

            document.getElementById('btnPlaceOrderText').classList.add('d-none');
            document.getElementById('btnPlaceOrderSpinner').classList.remove('d-none');
            document.getElementById('btnPlaceOrder').disabled = true;

            try {
                const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

                const payload = {
                    serviceId: selectedService.id,
                    link,
                    quantity: qty,
                    runs:     parseInt(document.getElementById('orderRuns')?.value || 0),
                    interval: parseInt(document.getElementById('orderInterval')?.value || 0)
                };

                const res = await fetch('/home/PlaceOrder', {

                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token },
                    body: JSON.stringify(payload)
                });
                const result = await res.json();

                if (result.success) {
                    alertBox.innerHTML = `
                        <div class="alert alert-success mb-3">
                            <strong>Order placed successfully!</strong><br>
                            Order ID: <strong>#${result.orderId}</strong><br>
                            Service: ${selectedService.name}<br>
                            Link: ${link}<br>
                            Quantity: ${qty}<br>
                            Charge: $${result.charge}
                        </div>`;
                    // Balance'ı güncelle
                    document.getElementById('orderQuantity').value = selectedService.minOrder;
                    calculateCharge();
                } else {
                    alertBox.innerHTML = `<div class="alert alert-danger mb-3">${result.message}</div>`;
                }

            } catch (err) {
                alertBox.innerHTML = `<div class="alert alert-danger mb-3">Connection error.</div>`;
                console.error(err);
            } finally {
                document.getElementById('btnPlaceOrderText').classList.remove('d-none');
                document.getElementById('btnPlaceOrderSpinner').classList.add('d-none');
                document.getElementById('btnPlaceOrder').disabled = false;
            }
        });

        // ── Event Listeners ───────────────────────────────────────

        // Kategori swiper butonu
        document.addEventListener('click', function (e) {
            const btn = e.target.closest('.nwo-cat-btn');
            if (!btn) return;

            document.querySelectorAll('.nwo-cat-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');

            const catId   = btn.dataset.catId;
            const catName = btn.dataset.catName;

            // Dropdown'ı da senkronize et
            document.getElementById('orderform-category').value = catId;

            filterServices(catId, document.getElementById('serviceSearch').value.trim());
        });

        // Kategori dropdown
        document.getElementById('orderform-category').addEventListener('change', function () {
            const catId = this.value;

            // Swiper butonunu da senkronize et
            document.querySelectorAll('.nwo-cat-btn').forEach(b => {
                b.classList.toggle('active', b.dataset.catId === catId);
            });
            // "All" butonu
            if (!catId) document.querySelector('.nwo-cat-btn[data-cat-id=""]')?.classList.add('active');

            filterServices(catId, document.getElementById('serviceSearch').value.trim());
        });

        // Servis dropdown
        document.getElementById('orderform-service').addEventListener('change', function () {
            onServiceSelected(this.value);
        });

        // Search
        document.getElementById('serviceSearch').addEventListener('input', function () {
            const catId = document.getElementById('orderform-category').value;
            filterServices(catId, this.value.trim());
        });

        // ── Filtrele ──────────────────────────────────────────────
        function filterServices(catId, searchText) {
            let filtered = allServices;

            if (catId) {
                filtered = filtered.filter(s => s.categoryId == catId);
            }

            if (searchText) {
                const lower = searchText.toLowerCase();
                filtered = filtered.filter(s =>
                    s.name.toLowerCase().includes(lower) ||
                    s.id.toString().includes(lower)
                );
            }

            buildServiceDropdown(filtered);
        }

        // ── Init ──────────────────────────────────────────────────
        loadServices();

    </script>
}
