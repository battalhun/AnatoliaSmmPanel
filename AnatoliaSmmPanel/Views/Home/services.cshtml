@model IEnumerable<AnatoliaSmmPanel.ViewModels.HomeServicesViewModel>
@{
    ViewData["Title"] = "Services";

    var categories = (Model ?? Enumerable.Empty<AnatoliaSmmPanel.ViewModels.HomeServicesViewModel>())
        .Select(x => new { Id = x.CategoryId, Name = string.IsNullOrEmpty(x.CategoryName) ? "General" : x.CategoryName })
        .GroupBy(x => x.Id)
        .Select(g => g.First())
        .ToList();
}

<script>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('[data-filter-category-id]').forEach(item => {
        item.addEventListener('click', function(e) {
          e.preventDefault();
          const id = this.getAttribute('data-filter-category-id');
          const name = this.getAttribute('data-filter-category-name') || 'Filters';

          const activeLabel = document.querySelector('[data-filter-active-category="true"]');
          if (activeLabel) activeLabel.textContent = id === 'All' ? 'Filters' : name;

          document.querySelectorAll('[data-filter-table-category-id]').forEach(row => {
            if (id === 'All' || row.getAttribute('data-filter-table-category-id') === id) {
              row.style.display = '';
            } else {
              row.style.display = 'none';
            }
          });
        });
      });

      // Search
      const searchInput = document.getElementById('filterServicesInput');
      if (searchInput) {
        searchInput.addEventListener('keyup', function () {
          const searchText = this.value.toLowerCase();
          const rows = document.querySelectorAll('#service-table tbody tr');

          let visibleCategories = new Set();

          rows.forEach(row => {
            if (row.hasAttribute('data-filter-table-service-name')) {
              const name = (row.querySelector('.service-name')?.textContent || '').toLowerCase();
              if (name.includes(searchText)) {
                row.style.display = '';
                visibleCategories.add(row.getAttribute('data-filter-table-category-id'));
              } else {
                row.style.display = 'none';
              }
            }
          });

          rows.forEach(row => {
            if (!row.hasAttribute('data-filter-table-service-name')) {
              const catId = row.getAttribute('data-filter-table-category-id');
              row.style.display = visibleCategories.has(catId) ? '' : 'none';
            }
          });
        });
      }

      // Tooltips
      [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        .forEach(el => new bootstrap.Tooltip(el));

      // Service detail modal population
      const serviceModal = document.getElementById('serviceDetailModal');
      if (serviceModal) {
        serviceModal.addEventListener('show.bs.modal', function (event) {
          const btn = event.relatedTarget;
          if (!btn) return;

          const id          = btn.getAttribute('data-service-id');
          const name        = btn.getAttribute('data-service-name');
          const rate        = btn.getAttribute('data-service-rate');
          const min         = btn.getAttribute('data-service-min');
          const max         = btn.getAttribute('data-service-max');
          const description = btn.getAttribute('data-service-description');

          document.getElementById('serviceModalTitle').textContent = name;
          document.getElementById('serviceModalIdValue').textContent = id;
          document.getElementById('serviceModalRateValue').textContent = rate;
          document.getElementById('serviceModalMin').textContent = min;
          document.getElementById('serviceModalMax').textContent = max;

          const descBox = document.getElementById('serviceModalDescription');
          if (description && description.trim()) {
            descBox.textContent = description;
            descBox.closest('.gcard').style.display = '';
          } else {
            descBox.closest('.gcard').style.display = 'none';
          }

          document.getElementById('serviceModalLink').href = '/new-order?select_service_id=' + id;
        });
      }
    });

    function copyToClipboard(text) {
      navigator.clipboard.writeText(text);
    }
</script>

<style>
    .well {
        overflow-x: auto;
        overflow-y: visible;
        -webkit-overflow-scrolling: touch;
    }
</style>

<div class="g-dash-content">
    <section class="pt-4">
        <div class="row">
            <div class="col-lg-12">
                <div class="service-top" style="background-color: var(--background-1-row);padding: 15px;border: 1px solid var(--border-color-1);">
                    <ul class="nav nav-pills" style="gap: 15px;">
                        <li>
                            <div class="dropdown">
                                <button class="btn btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    <span class="fas fa-filter"></span>
                                    <span data-filter-active-category="true">Filters</span>
                                    <span class="fas fa-caret-down" style="text-overflow: clip;"></span>
                                </button>
                                <ul class="dropdown-menu" style="width:auto!important;max-height: 400px;overflow: scroll;">
                                    @if (categories.Any())
                                    {
                                        <li>
                                            <a class="dropdown-item" href="#" data-filter-category-id="All">All Categories</a>
                                        </li>
                                    }
                                    @foreach (var category in categories)
                                    {
                                        <li>
                                            <a class="dropdown-item" href="#" data-filter-category-id="@category.Id" data-filter-category-name="@category.Name">@category.Name</a>
                                        </li>
                                    }
                                </ul>


                            </div>

                        </li>
                        <div class="col-lg">
                            <div class="g-search">
                                <div class="g-ticon">
                                    <i class="ri-search-line"></i>
                                </div>
                                <input type="text" class="textbox" name="query" id="filterServicesInput" placeholder="Search services" data-search-service="#service-table">
                            </div>
                        </div>
                    </ul>


                    <div style="margin: 15px;"></div>



                    <div class="well well-float">
                        <div class="service-tbl">
                            <table class="table" id="service-table">
                                <thead>
                                    <tr>
                                        <th style="font-size: 12px; width: 70px;">ID</th>
                                        <th style="font-size: 12px; width: 500px;" class="width-service-name">Service Name</th>
                                        <th style="font-size: 12px; width: 100px;" class="nowrap">Rate</th>
                                        <th style="font-size: 12px; width: 100px;" class="nowrap" data-bs-toggle="tooltip" data-bs-placement="top" title="Min Order - Max Order">Min - Max </th>
                                        <th style="font-size: 12px; width: 100px;" class="hidden-xs hidden-sm service-description__th">Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null && Model.Any())
                                    {
                                        var groupedServices = Model.GroupBy(x => new { x.CategoryId, CategoryName = string.IsNullOrEmpty(x.CategoryName) ? "General" : x.CategoryName });

                                        foreach (var categoryGroup in groupedServices)
                                        {
                                            <tr data-filter-table-category-id="@categoryGroup.Key.CategoryId" style="font-size: 12px;">
                                                <td colspan="100%" style="padding: 15px;padding-left: 10px;">
                                                    <strong>@categoryGroup.Key.CategoryName</strong>
                                                </td>
                                            </tr>

                                            foreach (var service in categoryGroup)
                                            {
                                                <tr data-filter-table-category-id="@categoryGroup.Key.CategoryId" data-filter-table-service-name="true">
                                                    <td style="font-size: 12px;" data-filter-table-service-id="@service.Id">@service.Id</td>
                                                    <td class="service-name" style="font-size: 12px;">@service.Name</td>
                                                    <td style="font-size: 12px;">@service.Rate.ToString("0.0000")</td>
                                                    <td style="font-size: 12px;">
                                                        @service.Min&nbsp;&nbsp;-&nbsp;&nbsp;@service.Max
                                                    </td>
                                                    <td style="font-size: 12px;" class="hidden-xs hidden-sm service-description">
                                                        <button style="font-size: 12px; padding: 5px 10px;" class="btn btn-primary btn-rounded btn-sm"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#serviceDetailModal"
                                                                data-service-id="@service.Id"
                                                                data-service-name="@service.Name"
                                                                data-service-rate="@service.Rate.ToString("0.0000")"
                                                                data-service-min="@service.Min"
                                                                data-service-max="@service.Max"
                                                                data-service-description="@System.Net.WebUtility.HtmlEncode(service.Description ?? "")">
                                                            View
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- SERVICE DETAIL MODAL -->
<div class="modal fade" id="serviceDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title" id="serviceModalTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">

                <div class="modal-flex">
                    <div class="mf-text">
                        <div class="d-flex text-center">
                            <span id="serviceModalTitleCenter"></span>
                        </div>
                    </div>
                </div>

                <div class="modal-flex">
                    <div class="mf-title">ID</div>
                    <div class="mf-text">
                        <div class="d-flex">
                            <span id="serviceModalIdValue"></span>
                            <div>
                                <i class="ri-file-copy-line cursor-pointer pl-2" onclick="copyToClipboard(document.getElementById('serviceModalIdValue').textContent)"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-flex">
                    <div class="mf-title">Rate</div>
                    <div class="mf-text">
                        <strong id="serviceModalRateValue"></strong>
                    </div>
                </div>

                <div class="gcard">
                    <div class="align-items-center gap-1"></div>
                    <div class="gcard-body news-item" style="max-height: 300px; overflow-y: scroll" id="serviceModalDescription"></div>
                </div>

                <div class="modal-flex">
                    <div class="mf-title">Amount</div>
                    <div class="mf-text">Min. <span class="mf-color" id="serviceModalMin"></span> Max. <span class="mf-color" id="serviceModalMax"></span></div>
                </div>

                <span id="serviceModalLinkWrapper">
                    <a id="serviceModalLink" href="#" style="position: relative; padding: 15px 40px; font-weight: 700;" class="btn btn-primary btn-block w-100">Create Order</a>
                </span>

            </div>
        </div>
    </div>
</div>
