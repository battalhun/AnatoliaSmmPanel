<div class="homeSection">
    <div class="container" style="background: var(--background-1-row); padding: 60px; border: 1px solid var(--border-color-1); border-radius: 10px;">
        
        <div class="text-center mb-5">
            <p class="h2">Sign In</p>
        </div>

        <div class="well">
            <form id="account" method="post">
                
                <!-- Hata mesajları -->
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="singin-row hmFlex-col">

                    <!-- EMAIL -->
                    <div class="form-group mb-3">
                        <label asp-for="Input.Email" class="control-label mb-2">Email</label>
                        <input asp-for="Input.Email"
                               class="form-control form-control-singin mb-2"
                               style="height: 50px; width: 350px;" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>

                        <div class="form-check mt-2">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label class="form-check-label" asp-for="Input.RememberMe">
                                Remember Me
                            </label>
                        </div>
                    </div>

                    <!-- PASSWORD -->
                    <div class="form-group form-group__password mb-3">
                        <label asp-for="Input.Password" class="control-label mb-2">Password</label>
                        <input asp-for="Input.Password"
                               class="form-control form-control-singin mb-2"
                               style="height: 50px; width: 350px;" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>

                        <a asp-page="./ForgotPassword" class="forgot-password">
                            Forgot password?
                        </a>
                    </div>

                    <!-- BUTTON -->
                    <div class="form-group">
                        <button id="login-submit" type="submit" class="singin-btn">
                            Sign In
                        </button>
                    </div>
                </div>

                <!-- REGISTER -->
                <div class="singin-row hmFlex-col" style="justify-content: left; margin-left: 180px;">
                    <span class="mt-4" style="color: var(--text-color-transparent)">
                        Don’t have an account?
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
                            Sign Up
                        </a>
                    </span>
                </div>

                <!-- EXTERNAL LOGIN -->
                @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                {
                    <div class="mt-4">
                        <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            @foreach (var provider in Model.ExternalLogins)
                            {
                                <button type="submit"
                                        class="btn btn-outline-primary me-2 mt-2"
                                        name="provider"
                                        value="@provider.Name">
                                    @provider.DisplayName ile giriş yap
                                </button>
                            }
                        </form>
                    </div>
                }

            </form>
        </div>
    </div>
</div>


