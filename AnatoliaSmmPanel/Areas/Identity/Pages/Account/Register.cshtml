@page "/signup"
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<section class="regArea">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 d-none d-md-block">
                <div class="regRight mt-5 mt-lg-0">
                    <div class="regSteps">
                        <ul class="list-unstyled mb-0">
                            <li class="d-md-flex justify-content-between align-items-center mb-3">
                                <div class="me-3">
                                    <i class="fas fa-exclamation-triangle"></i>
                                </div>
                                <div>
                                    <h6>Your Security Matters</h6>
                                    <p class="m-0">
                                        We prioritize your security. While we request your first name, last name, and phone number for registration, please note that they are not mandatory fields. We ask for this information solely for your security and to enhance your experience with us. Additionally, having this information may be necessary for processing refunds and ensuring secure transactions.
                                    </p>
                                </div>
                            </li>

   
                                  
                            <li class="d-md-flex justify-content-between align-items-center mb-3">
                                <div class="me-3">
                                    <i class="far fa-bullseye-pointer"></i>
                                </div>
                                <div>
                                    <h6>Automatic Delivery</h6>
                                    <p class="m-0">
                                        In our fully automatic dealership panel, the orders you place are processed and completed automatically.
                                    </p>
                                </div>
                            </li>
                            <li class="d-md-flex justify-content-between align-items-center mb-3">
                                <div class="me-3">
                                    <i class="far fa-credit-card"></i>
                                </div>
                                <div>
                                    <h6>Secure Payment</h6>
                                    <p class="m-0">
                                        You can make your payments securely 24 hours a day with our contracted payment methods.
                                    </p>
                                </div>
                            </li>
                            <li class="d-md-flex justify-content-between align-items-center">
                                <div class="me-3">
                                    <i class="far fa-gem"></i>
                                </div>
                                <div>
                                    <h6>Quality service</h6>
                                    <p class="m-0">
                                        We are working to give you the best service with quality and affordable services.
                                    </p>
                                </div>
                            </li>

                                
                        </ul>

                               
                              
                              
                    </div>
                </div>

            </div>
            <div class="col-lg-6">
			
                <div class="gcard">
                    <div class="gcard-header">
                        <div class="row align-items-center">
                            <div class="col d-flex align-items-center">
                                <div class="ch-g-ticon">
                                    <div class="gcard-head-icon">
                                        <i class="ri-user-add-line"></i>
                                    </div>
                                </div>
                                <div class="ch-text">
                                    <h3 class="gcard-title">Register now!</h3>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="gcard-body">

                        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
    
                            <h2>Create a new account.</h2>
                            <hr />

                            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                            <!-- Email -->
                            <div class="form-group mb-3">
                                <input asp-for="Input.Email"
                                       class="form-control"
                                       autocomplete="username"
                                       placeholder="Email" />
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>

                            <!-- Password -->
                            <div class="form-group mb-3">
                                <input asp-for="Input.Password"
                                       class="form-control"
                                       autocomplete="new-password"
                                       placeholder="Password" />
                                <span asp-validation-for="Input.Password" class="text-danger"></span>
                            </div>

                            <!-- Confirm Password -->
                            <div class="form-group mb-3">
                                <input asp-for="Input.ConfirmPassword"
                                       class="form-control"
                                       autocomplete="new-password"
                                       placeholder="Confirm Password" />
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                            </div>

                           @*  <!-- Terms (check_agreement karşılığı) -->
                            <div class="form-group mb-3">
                                <div class="form-check">
                                    <input class="form-check-input"
                                           asp-for="Input.AcceptTerms" />
                                    <label class="form-check-label">
                                        I accept the <a asp-page="/Terms" target="_blank">terms of service</a>
                                    </label>
                                </div>
                            </div> *@

                            @* <!-- CAPTCHA (site['captcha']) -->
                            @if (Model.ShowCaptcha)
                            {
                                <div class="mb-3">
                                    @Model.CaptchaHtml
                                </div>
                            } *@

                            <!-- Google Sign-in -->
                            @* @if (Model.ExternalLogins?.Count > 0)
                            {
                                <div class="mb-3">
                                    <div id="g_id_onload"
                                         data-client_id="@Model.GoogleClientId"
                                         data-login_uri="@Model.GoogleRedirectUrl"
                                         data-auto_prompt="false">
                                    </div>

                                    <div class="g_id_signin"
                                         data-type="standard"
                                         data-size="large"
                                         data-theme="outline"
                                         data-text="signup_with">
                                    </div>
                                </div>
                            } *@

                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn btn-primary w-100">
                                Register
                            </button>

                        </form>


                @*         <form {% if site['rtl'] %}class="rtl-form" {% endif %} action="" method="post">
                            {% if error %}
                            <div class="alert alert-dismissible alert-danger {% if site['rtl'] %} rtl-alert {% endif %}">
                                <button type="button" class="close" data-dismiss="alert">&times;</button>
                                {{ errorMessage }}
                            </div>
                            {% endif %}
                            {% if success %}
                            <div class="alert alert-dismissible alert-success {% if site['rtl'] %} rtl-alert {% endif %}">
                                <button type="button" class="close" data-dismiss="alert">&times;</button>
                                {{ successText }}
                            </div>
                            {% endif %}

                            {% for field in fields %}
                            <div class="form-group">
                                <input type="{{ field.type }}" class="form-control" id="{{ field.code }}" value="{{ field.value }}" name="RegistrationForm[{{ field.code }}]" placeholder="{{ lang(field.label) }}">
                            </div>
                            {% endfor %}
                            {% if site['captcha'] %}
                            {{ captchaCode }}
                            {% endif %}
                            {% if googleSignIn %}
                            <div class="form-group">
                                <div id="g_id_onload"
                                     data-client_id="{{ googleClientId }}"
                                     data-login_uri="{{ googleSignInRedirectUrl }}"
                                     data-auto_prompt="false"
                                     data-_csrf="{{csrftoken}}">
                                </div>
                                <div class="g_id_signin"
                                     data-type="standard"
                                     data-size="large"
                                     data-theme="outline"
                                     data-text="signup_with"
                                     data-shape="rectangular"
                                     data-logo_alignment="left">
                                </div>
                            </div>
                            {% endif %}
                            {% if check_agreement %}
                            <div class="form-group">
                                <div class="checkbox">
                                    <label>
                                        <input type="checkbox" class="terms-accept-checkbox" name="RegistrationForm[termsofservice]"> {{ lang('signup.accept_terms_text') }} <a href="{{ page_url('terms') }}" target="_blank">{{ lang('terms.signup_checkbox') }}</a>
                                    </label>
                                </div>
                            </div>
                            {% endif %}
						
                            <input type="hidden" name="_csrf" value="{{csrftoken}}">
                            <button type="submit" class="btn btn-primary btn-block">{{ lang('signup.button') }}</button>
                        </form> *@
                    </div>
                </div>
            </div>
		
        </div>
    </div>
</section>

