@model AnatoliaSmmPanel.Data.Models.Admin.Order

@Html.AntiForgeryToken()

<div class="modal-header bg-body-tertiary py-3">
    <h5 class="modal-title fw-bold">
        <i class="fas fa-flag-checkered me-2 text-primary"></i>
        Set Start Count
        <span class="badge bg-secondary ms-2 fw-normal fs-6">
            Order ID: (@Model.Id)
        </span>
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body p-4">

    <div id="setStartCountAlert"></div>

    <form id="setStartCountForm">

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Quantity</label>
                <input type="text" class="form-control bg-body-secondary text-muted" value="@Model.Quantity" disabled>
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold text-muted">Current Start Count</label>
                <input type="text" class="form-control bg-body-secondary text-muted" value="@Model.StartCount" disabled>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-12">
                <label for="setStartCountInput" class="form-label fw-semibold">
                    New Start Count (Başlangıç Sayısı) <span class="text-danger">*</span>
                </label>
                <input type="number"
                       id="setStartCountInput"
                       class="form-control bg-body form-control-lg"
                       min="0"
                       value="@Model.StartCount"
                       required>
                <div class="form-text text-muted">
                    <i class="fas fa-info-circle me-1"></i>
                    Sipariş başladığında linkteki mevcut sayaç/takipçi değerini giriniz.
                </div>
                <div class="invalid-feedback">Please enter a valid start count.</div>
            </div>
        </div>

        <input type="hidden" id="setStartCountOrderId" value="@Model.Id">

    </form>

</div>

<div class="modal-footer bg-body-tertiary p-3">
    <button type="button"
            class="btn btn-link text-decoration-none text-secondary"
            data-bs-dismiss="modal">
        Cancel
    </button>
    <button type="button"
            id="btnSaveStartCount"
            class="btn btn-primary px-5 shadow-sm">
        <span id="btnSaveStartCountText">
            <i class="fas fa-save me-2"></i>Save Changes
        </span>
        <span id="btnSaveStartCountSpinner" class="d-none">
            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            Saving...
        </span>
    </button>
</div>

<script>
    (function () {

        document.getElementById('btnSaveStartCount').addEventListener('click', async function () {

            const startCountInput = document.getElementById('setStartCountInput');
            const startCountValue = parseInt(startCountInput.value);

            if (isNaN(startCountValue) || startCountValue < 0) {
                startCountInput.classList.add('is-invalid');
                return;
            }
            startCountInput.classList.remove('is-invalid');

            const payload = {
                id: parseInt(document.getElementById('setStartCountOrderId').value),
                startCount: startCountValue
            };

            // Buton durum kilitlemeleri
            document.getElementById('btnSaveStartCountText').classList.add('d-none');
            document.getElementById('btnSaveStartCountSpinner').classList.remove('d-none');
            document.getElementById('btnSaveStartCount').disabled = true;

            try {
                const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

                const response = await fetch('/admin/orders/SetStartCount', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': token
                    },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();

                if (result.success) {
                    document.getElementById('setStartCountAlert').innerHTML = `
                        <div class="alert alert-success d-flex align-items-center gap-2 py-2">
                            <i class="fas fa-check-circle"></i>
                            Start count updated successfully.
                        </div>`;

                    if (typeof loadOrders === 'function') {
                        loadOrders(); // Ana sayfadaki tabloyu yeniler
                    }

                    setTimeout(() => {
                        bootstrap.Modal.getInstance(document.getElementById('dynamicModal'))?.hide();
                    }, 1200);

                } else {
                    document.getElementById('setStartCountAlert').innerHTML = `
                        <div class="alert alert-danger d-flex align-items-center gap-2 py-2">
                            <i class="fas fa-exclamation-circle"></i>
                            ${result.message || 'An error occurred.'}
                        </div>`;
                }

            } catch (err) {
                document.getElementById('setStartCountAlert').innerHTML = `
                    <div class="alert alert-danger py-2">
                        <i class="fas fa-exclamation-circle me-2"></i>Connection error.
                    </div>`;
            } finally {
                document.getElementById('btnSaveStartCountText').classList.remove('d-none');
                document.getElementById('btnSaveStartCountSpinner').classList.add('d-none');
                document.getElementById('btnSaveStartCount').disabled = false;
            }
        });

    })();
</script>