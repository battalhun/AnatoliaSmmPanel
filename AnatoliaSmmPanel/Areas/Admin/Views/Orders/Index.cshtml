@{
    ViewData["Title"] = "Orders";
}

<style>
    .order-row-secondary td {
        background: var(--bs-body-bg);
        font-size: 0.8rem;
        color: var(--bs-secondary-color);
        border-top: none !important;
        padding-top: 2px !important;
    }
</style>

<div class="d-flex flex-column vh-100 bg-body-tertiary shadow-sm" style="padding: 10px; border-radius: 5px;">

    <!-- HEADER -->
    <header class="container-fluid py-3 border-bottom bg-body-tertiary">
        <div class="row align-items-center g-2">

            <!-- Status Tabs -->
            <div class="col-12 col-md-auto">
                <div class="d-flex flex-wrap gap-1" id="statusTabs">
                    @foreach (var s in new[] { "All", "Awaiting", "Pending", "In progress", "Completed", "Partial", "Canceled", "Processing", "Fail", "Error" })
                    {
                        <button class="btn btn-sm @(s == "All" ? "btn-primary" : "btn-outline-secondary") status-tab-btn"
                                data-status="@s">
                            @s
                        </button>
                    }
                </div>
            </div>

            <!-- Search + Export -->
            <div class="col-12 col-md-auto ms-md-auto">
                <div class="d-flex gap-2 align-items-center">
                    <button class="btn btn-sm btn-outline-secondary" onclick="exportOrders()">
                        <i class="fas fa-file-export me-1"></i> Export
                    </button>
                    <div class="input-group input-group-sm" style="min-width: 280px;">
                        <span class="input-group-text bg-body border-end-0">
                            <i class="fas fa-search text-muted"></i>
                        </span>
                        <input type="text" id="ordersSearch" class="form-control border-start-0 bg-body" placeholder="Search...">
                        <select class="form-select bg-body border-start-0" id="searchField" style="max-width: 130px;">
                            <option value="all">All Fields</option>
                            <option value="id">Order ID</option>
                            <option value="link">Link</option>
                            <option value="user">Username</option>
                            <option value="service">Service ID</option>
                        </select>
                        <button class="btn btn-outline-secondary" type="button" onclick="loadOrders()">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </header>

    <main class="flex-grow-1 d-flex flex-column overflow-hidden">

        <div class="border-bottom bg-body-tertiary" style="z-index: 10; padding-right: 17px;">
            <table class="table table-sm mb-0 custom-table table-fixed">
                <colgroup>
                    <col style="width: 50px;">
                    <col style="width: 80px;">
                    <col style="width: 130px;">
                    <col style="width: 90px;">
                    <col>
                    <col style="width: 90px;">
                    <col style="width: 80px;">
                    <col style="width: 200px;">
                    <col style="width: 110px;">
                    <col style="width: 70px;">
                    <col style="width: 140px;">
                    <col style="width: 70px;">
                    <col style="width: 100px;">
                </colgroup>
                <thead class="bg-body-secondary border-bottom">
                    <tr>
                        <th class="text-center">
                            <input class="form-check-input" type="checkbox" id="checkAll">
                        </th>
                        <th>ID</th>
                        <th>User</th>
                        <th>Charge</th>
                        <th>Link</th>
                        <th>Start</th>
                        <th>Qty</th>
                        <th>Service</th>
                        <th>Status</th>
                        <th>Remains</th>
                        <th>Created</th>
                        <th>Mode</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>


        <div id="scrollArea" class="flex-grow-1 overflow-auto">
            <table class="table table-hover mb-0 custom-table table-fixed align-middle" id="ordersTable">
                <colgroup>
                    <col style="width: 50px;">
                    <col style="width: 80px;">
                    <col style="width: 130px;">
                    <col style="width: 90px;">
                    <col>
                    <col style="width: 90px;">
                    <col style="width: 80px;">
                    <col style="width: 200px;">
                    <col style="width: 110px;">
                    <col style="width: 70px;">
                    <col style="width: 140px;">
                    <col style="width: 70px;">
                    <col style="width: 100px;">
                </colgroup>
                <tbody id="ordersTableBody">
                    <tr>
                        <td colspan="13" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

    </main>

    <!-- FOOTER -->
    <footer class="container-fluid py-2 border-top bg-body-tertiary">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">

            <!-- Mass Actions -->
            <div id="massActionsBar" class="d-none d-flex align-items-center gap-2">
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                        <i class="fas fa-bolt me-1"></i> Actions
                    </button>
                    <ul class="dropdown-menu shadow">
                        <li><h6 class="dropdown-header">Change Status</h6></li>
                        <li><a class="dropdown-item" href="#" onclick="massChangeStatus('Pending')">Pending</a></li>
                        <li><a class="dropdown-item" href="#" onclick="massChangeStatus('In progress')">In progress</a></li>
                        <li><a class="dropdown-item" href="#" onclick="massChangeStatus('Processing')">Processing</a></li>
                        <li><a class="dropdown-item" href="#" onclick="massChangeStatus('Completed')">Completed</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="#" onclick="massCancelRefund()">Cancel and refund</a></li>
                    </ul>
                </div>
                <span class="small text-muted" id="selectedOrdersCount">0 orders selected</span>
            </div>

            <div id="noSelectionBar" class="small text-muted">Select orders for mass actions</div>

            <div class="d-flex align-items-center gap-3">
                <!-- Pagination -->
                <div id="paginationContainer" class="d-flex gap-1"></div>
                <span class="badge bg-secondary px-3 py-2" id="totalCount">Total: —</span>
            </div>

        </div>
    </footer>

</div>

<!-- Dinamik Modal -->
<div class="modal fade" id="dynamicModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow" id="dynamicModalBody">
            <div class="text-center p-5">
                <div class="spinner-border text-primary" role="status"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modal.js"></script>

    <script>

        let currentStatus = 'All';
        let currentPage = 1;
        const pageSize = 100;

        // ── Status Badge ─────────────────────────────────────────
        function statusBadge(status) {
            const map = {
                'Completed':   'bg-success-subtle text-success border border-success-subtle',
                'In progress': 'bg-primary-subtle text-primary border border-primary-subtle',
                'Pending':     'bg-warning-subtle text-warning border border-warning-subtle',
                'Awaiting':    'bg-info-subtle text-info border border-info-subtle',
                'Processing':  'bg-secondary-subtle text-secondary border border-secondary-subtle',
                'Partial':     'bg-warning-subtle text-warning border border-warning-subtle',
                'Canceled':    'bg-danger-subtle text-danger border border-danger-subtle',
                'Fail':        'bg-danger-subtle text-danger border border-danger-subtle',
                'Error':       'bg-danger-subtle text-danger border border-danger-subtle',
            };
            const cls = map[status] || 'bg-secondary-subtle text-secondary';
            return `<span class="badge ${cls}">${status}</span>`;
        }

        function formatDate(str) {
            if (!str) return '—';
            return str.substring(0, 16).replace('T', ' ');
        }

        function truncateLink(link, max = 35) {
            if (!link) return '—';
            return link.length > max ? link.substring(0, max) + '…' : link;
        }

        // Domları renderlama
        function renderRows(orders) {
            const tbody = document.getElementById('ordersTableBody');

            if (!orders.length) {
                tbody.innerHTML = `<tr><td colspan="13" class="text-center py-5 text-muted">No orders found.</td></tr>`;
                return;
            }

            tbody.innerHTML = orders.map(o => `
                <tr class="order-row" data-id="${o.id}">
                    <td class="text-center">
                        <input class="form-check-input order-checkbox" type="checkbox" value="${o.id}">
                    </td>
                    <td class="text-muted fw-semibold">${o.id}</td>
                    <td>
                        <span class="fw-semibold">${o.userEmail ?? o.userEmail ?? o.userNickname}</span>
                    </td>
                    <td class="text-end fw-semibold">$${parseFloat(o.charge ?? 0).toFixed(4)}</td>
                    <td class="text-truncate" style="max-width:1px;" title="${o.link ?? ''}">
                        ${o.link
                            ? `<a href="${o.link}" target="_blank" rel="noopener noreferrer" class="text-decoration-none small">${truncateLink(o.link)}</a>`
                            : '—'}
                    </td>
                    <td class="text-muted small">${o.startCount ?? '—'}</td>
                    <td class="text-muted small">${o.quantity}</td>
                    <td>
                        <div class="small">
                            <span class="badge bg-secondary-subtle text-secondary border me-1">${o.serviceId}</span>
                            <span class="text-truncate d-inline-block" style="max-width: 140px; vertical-align: middle;" title="${o.serviceName ?? ''}">${o.serviceName ?? '—'}</span>
                        </div>
                    </td>
                    <td>${statusBadge(o.status)}</td>
                    <td class="text-muted small text-center">${o.remains ?? 0}</td>
                    <td class="small text-muted">${formatDate(o.createdAt)}</td>
                    <td class="small text-muted">${o.mode ?? 'Auto'}</td>
                    <td class="text-end pe-3">
                        <div class="btn-group">
                            <button class="btn btn-sm btn-light border dropdown-toggle" data-bs-toggle="dropdown">
                                Actions
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow">
                                <li><a class="dropdown-item" href="javascript:void(0)" onclick="orderDetails(${o.id})">
                                    <i class="fas fa-info-circle me-2 text-primary"></i>Details
                                </a></li>
                                <li><a class="dropdown-item" href="javascript:void(0)" onclick="setStartCount(${o.id})">
                                    <i class="fas fa-flag-checkered me-2"></i>Set start count
                                </a></li>
                                <li><a class="dropdown-item" href="javascript:void(0)" onclick="setPartial(${o.id})">
                                    <i class="fas fa-adjust me-2"></i>Set partial
                                </a></li>
                                ${o.status !== 'Completed' && o.status !== 'Canceled' ? `
                                <li>
                                    <div class="dropdown-item p-0">
                                        <div class="dropdown dropend">
                                            <a class="dropdown-item" data-bs-toggle="dropdown">
                                                <i class="fas fa-exchange-alt me-2"></i>Change status
                                            </a>
                                            <ul class="dropdown-menu shadow">
                                                <li><a class="dropdown-item" href="javascript:void(0)" onclick="changeStatus(${o.id}, 'Pending')">Pending</a></li>
                                                <li><a class="dropdown-item" href="javascript:void(0)" onclick="changeStatus(${o.id}, 'In progress')">In progress</a></li>
                                                <li><a class="dropdown-item" href="javascript:void(0)" onclick="changeStatus(${o.id}, 'Processing')">Processing</a></li>
                                                <li><a class="dropdown-item" href="javascript:void(0)" onclick="changeStatus(${o.id}, 'Completed')">Completed</a></li>
                                            </ul>
                                        </div>
                                    </div>
                                </li>` : ''}
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="javascript:void(0)" onclick="cancelRefund(${o.id})">
                                    <i class="fas fa-times-circle me-2"></i>Cancel and refund
                                </a></li>
                            </ul>
                        </div>
                    </td>
                </tr>
                <tr class="order-row-secondary">
                    <td colspan="2" class="ps-3 text-muted">#${o.externalOrderId ?? '—'}</td>
                    <td colspan="2" class="text-muted">
                        $${parseFloat(o.providerCharge ?? 0).toFixed(4)}
                    </td>
                    <td colspan="5" class="text-muted">${o.providerName ?? '—'}</td>
                    <td colspan="4"></td>
                </tr>
            `).join('');
        }

        // ── Load ─────────────────────────────────────────────────
        async function loadOrders() {
            const search = document.getElementById('ordersSearch').value.trim();
            const field  = document.getElementById('searchField').value;

            document.getElementById('ordersTableBody').innerHTML =
                `<tr><td colspan="13" class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></td></tr>`;

            try {
                const params = new URLSearchParams({
                    status: currentStatus === 'All' ? '' : currentStatus,
                    page: currentPage,
                    pageSize,
                    search,
                    field
                });

                const res  = await fetch(`/admin/orders/GetAll?${params}`);
                const data = await res.json();

                if (data.success) {
                    renderRows(data.data);
                    document.getElementById('totalCount').textContent = `Total: ${data.total}`;
                    renderPagination(data.total);
                }
            } catch (e) {
                document.getElementById('ordersTableBody').innerHTML =
                    `<tr><td colspan="13" class="text-center py-4 text-danger">Failed to load orders.</td></tr>`;
            }
        }

        // ── Pagination ───────────────────────────────────────────
        function renderPagination(total) {
            const totalPages = Math.ceil(total / pageSize);
            const container = document.getElementById('paginationContainer');
            if (totalPages <= 1) { container.innerHTML = ''; return; }

            let html = '';
            const start = Math.max(1, currentPage - 2);
            const end   = Math.min(totalPages, currentPage + 2);

            if (currentPage > 1)
                html += `<button class="btn btn-sm btn-outline-secondary" onclick="goPage(${currentPage - 1})">‹</button>`;

            for (let i = start; i <= end; i++)
                html += `<button class="btn btn-sm ${i === currentPage ? 'btn-primary' : 'btn-outline-secondary'}" onclick="goPage(${i})">${i}</button>`;

            if (currentPage < totalPages)
                html += `<button class="btn btn-sm btn-outline-secondary" onclick="goPage(${currentPage + 1})">›</button>`;

            container.innerHTML = html;
        }

        function goPage(page) {
            currentPage = page;
            loadOrders();
        }

        // ── Status Tabs ──────────────────────────────────────────
        document.getElementById('statusTabs').addEventListener('click', function (e) {
            const btn = e.target.closest('.status-tab-btn');
            if (!btn) return;

            document.querySelectorAll('.status-tab-btn').forEach(b => {
                b.classList.remove('btn-primary');
                b.classList.add('btn-outline-secondary');
            });
            btn.classList.add('btn-primary');
            btn.classList.remove('btn-outline-secondary');

            currentStatus = btn.dataset.status;
            currentPage   = 1;
            loadOrders();
        });

        // ── Check All ────────────────────────────────────────────
        document.getElementById('checkAll').addEventListener('change', function () {
            document.querySelectorAll('.order-checkbox').forEach(cb => cb.checked = this.checked);
            updateMassActions();
        });

        document.addEventListener('change', function (e) {
            if (e.target.classList.contains('order-checkbox')) updateMassActions();
        });

        function updateMassActions() {
            const count  = document.querySelectorAll('.order-checkbox:checked').length;
            const bar    = document.getElementById('massActionsBar');
            const noBar  = document.getElementById('noSelectionBar');
            document.getElementById('selectedOrdersCount').textContent = `${count} orders selected`;
            bar.classList.toggle('d-none', count === 0);
            noBar.classList.toggle('d-none', count > 0);
        }

            // ── Actions ──────────────────────────────────────────────
            function orderDetails(id)   { setModalSize('lg'); openDynamicModal(`/admin/orders/Details/${id}`); }
            function setStartCount(id)  { setModalSize('');   openDynamicModal(`/admin/orders/SetStartCount/${id}`); }
            function setPartial(id)     { setModalSize('');   openDynamicModal(`/admin/orders/SetPartial/${id}`); }

            async function changeStatus(id, status) {
                const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
                await fetch('/admin/orders/ChangeStatus', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token },
                    body: JSON.stringify({ id, status })
                });
                loadOrders();
            }

            async function cancelRefund(id) {
                if (!confirm('Cancel this order and refund the user?')) return;
                const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
                await fetch('/admin/orders/CancelRefund', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token },
                    body: JSON.stringify({ id })
                });
                loadOrders();
            }

            async function massChangeStatus(status) {
                const ids = [...document.querySelectorAll('.order-checkbox:checked')].map(cb => parseInt(cb.value));
                if (!ids.length) return;
                const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
                await fetch('/admin/orders/MassChangeStatus', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token },
                    body: JSON.stringify({ ids, status })
                });
                loadOrders();
            }

            async function massCancelRefund() {
                const ids = [...document.querySelectorAll('.order-checkbox:checked')].map(cb => parseInt(cb.value));
                if (!ids.length || !confirm(`Cancel and refund ${ids.length} orders?`)) return;
                const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
                await fetch('/admin/orders/MassCancelRefund', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token },
                    body: JSON.stringify({ ids })
                });
                loadOrders();
            }

            function exportOrders() {
                const status = currentStatus === 'All' ? '' : currentStatus;
                window.location.href = `/admin/orders/Export?status=${status}`;
            }

        // ── Init ─────────────────────────────────────────────────
        loadOrders();

        document.getElementById('ordersSearch').addEventListener('keydown', function (e) {
            if (e.key === 'Enter') loadOrders();
        });

    </script>
}
