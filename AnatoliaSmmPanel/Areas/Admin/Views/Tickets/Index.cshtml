@model AnatoliaSmmPanel.Areas.Admin.ViewModels.Tickets.TicketsViewModel
@{
    ViewData["Title"] = "Tickets";
}

<div class="d-flex flex-column vh-100 bg-body-tertiary shadow-sm" style="padding: 10px; border-radius: 5px;">

    <!-- HEADER -->
    <header class="container-fluid py-3 border-bottom bg-body-tertiary">
        <div class="row align-items-center g-2">

            <!-- Status Tabs -->
            <div class="col-12 col-md-auto">
                <div class="d-flex flex-wrap gap-1" id="statusTabs">
                    @foreach (var s in new[] { "All", "Pending", "Answered", "Closed" })
                    {
                        <button class="btn btn-sm @(s == "All" ? "btn-primary" : "btn-outline-secondary") status-tab-btn"
                                data-status="@s">
                            @s
                        </button>
                    }
                </div>
            </div>

            <!-- Search + New Ticket -->
            <div class="col-12 col-md-auto ms-md-auto">
                <div class="d-flex gap-2 align-items-center">
                    <button class="btn btn-sm btn-primary" onclick="newTicket()">
                        <i class="fas fa-plus me-1"></i> New Ticket
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" onclick="exportTickets()">
                        <i class="fas fa-file-export me-1"></i> Export
                    </button>
                    <div class="input-group input-group-sm" style="min-width: 280px;">
                        <span class="input-group-text bg-body border-end-0">
                            <i class="fas fa-search text-muted"></i>
                        </span>
                        <input type="text" id="ticketsSearch" class="form-control border-start-0 bg-body" placeholder="Search...">
                        <select class="form-select bg-body border-start-0" id="searchField" style="max-width: 130px;">
                            <option value="all">All Fields</option>
                            <option value="id">Ticket ID</option>
                            <option value="user">Username</option>
                            <option value="subject">Subject</option>
                        </select>
                        <button class="btn btn-outline-secondary" type="button" onclick="loadTickets()">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </header>

    <!-- TABLE HEADER (fixed) -->
    <main class="flex-grow-1 d-flex flex-column overflow-hidden">

        <div class="border-bottom bg-body-tertiary" style="z-index: 10; padding-right: 17px;">
            <table class="table table-sm mb-0 custom-table table-fixed">
                <colgroup>
                    <col style="width: 80px;">
                    <col style="width: 160px;">
                    <col>
                    <col style="width: 120px;">
                    <col style="width: 160px;">
                    <col style="width: 160px;">
                    <col style="width: 110px;">
                </colgroup>
                <thead class="bg-body-secondary border-bottom">
                    <tr>
                        <th>ID</th>
                        <th>User</th>
                        <th>Subject</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Updated</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>

        <!-- SCROLLABLE BODY -->
        <div id="scrollArea" class="flex-grow-1 overflow-auto">
            <table class="table table-hover mb-0 custom-table table-fixed align-middle" id="ticketsTable">
                <colgroup>
                    <col style="width: 80px;">
                    <col style="width: 160px;">
                    <col>
                    <col style="width: 120px;">
                    <col style="width: 160px;">
                    <col style="width: 160px;">
                    <col style="width: 110px;">
                </colgroup>
                <tbody id="ticketsTableBody">
                    <tr>
                        <td colspan="7" class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

    </main>

    <!-- FOOTER -->
    <footer class="container-fluid py-2 border-top bg-body-tertiary">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="d-flex align-items-center gap-3">
                <div id="paginationContainer" class="d-flex gap-1"></div>
                <span class="badge bg-secondary px-3 py-2" id="totalCount">Total: —</span>
            </div>
        </div>
    </footer>

</div>

<!-- Dinamik Modal -->
<div class="modal fade" id="dynamicModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow" id="dynamicModalBody">
            <div class="text-center p-5">
                <div class="spinner-border text-primary" role="status"></div>
            </div>
        </div>
    </div>
</div>

<!-- CONFIRM MODAL (sayfada bir kez bulunmalı) -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmModalTitle">Are you sure?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="confirmModalBody" class="mb-0">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-link text-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger px-4" id="confirmModalConfirmBtn">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {

    <script src="~/js/modal.js"></script>

    <script>

        let currentStatus = 'All';
        let currentPage = 1;
        const pageSize = 100;

        function statusBadge(status) {
            const map = {
                'Pending':  'bg-warning-subtle text-warning border border-warning-subtle',
                'Answered': 'bg-success-subtle text-success border border-success-subtle',
                'Closed':   'bg-secondary-subtle text-secondary border border-secondary-subtle',
            };
            const cls = map[status] || 'bg-secondary-subtle text-secondary';
            return `<span class="badge ${cls}">${status}</span>`;
        }

        function formatDate(str) {
            if (!str) return '—';
            return str.substring(0, 16).replace('T', ' ');
        }

        function renderRows(tickets) {
            const tbody = document.getElementById('ticketsTableBody');

            if (!tickets.length) {
                tbody.innerHTML = `<tr><td colspan="7" class="text-center py-5 text-muted">No tickets found.</td></tr>`;
                return;
            }

            tbody.innerHTML = tickets.map(t => `
                <tr class="${t.isUnread ? 'fw-bold' : ''}">
                    <td class="text-muted">#${t.id}</td>
                    <td>${t.userNickname ?? `User #${t.userId}`}</td>
                    <td class="text-truncate" style="max-width:1px;" title="${t.subject ?? ''}">
                        ${t.isUnread ? '<i class="fas fa-circle text-primary me-1" style="font-size:6px;"></i>' : ''}
                        ${t.subject ?? '—'}
                    </td>
                    <td>${statusBadge(t.status)}</td>
                    <td class="small text-muted">${formatDate(t.createdAt)}</td>
                    <td class="small text-muted">${formatDate(t.updatedAt)}</td>
                    <td class="text-end pe-3">
                        <div class="btn-group">
                            <button class="btn btn-sm btn-light border" onclick="ticketDetails(${t.id})">
                                <i class="fas fa-eye me-1"></i> View
                            </button>
                            <button class="btn btn-sm btn-light border dropdown-toggle" data-bs-toggle="dropdown"></button>
     <style>
.dropdown-submenu {
    position: relative;
}

.submenu-drop {
    top: 0;
    margin-top: -1px;
    display: none;
}

.submenu-drop__left {
    left: auto;
    right: 100%;
}

.dropdown-submenu:hover > .submenu-drop {
    display: block;
}

.dropdown-submenu__title::before {
    content: "";
    display: inline-block;
    margin-right: 0.5rem;
    vertical-align: middle;
    border-top: 0.3em solid transparent;
    border-bottom: 0.3em solid transparent;
    border-right: 0.3em solid currentColor;
}

.dropdown-submenu__title {
    display: flex;
    align-items: center;
}
</style>

<ul class="dropdown-menu dropdown-menu-end shadow">

    <li class="dropdown dropdown-submenu">
        <a href="javascript:void(0)" class="dropdown-item dropdown-submenu__title">Change status</a>
        <ul class="dropdown-menu submenu-drop submenu-drop__left shadow">
            <li><a class="dropdown-item" href="javascript:void(0)" onclick="changeStatus(${t.id}, 0)">Pending</a></li>
            <li><a class="dropdown-item" href="javascript:void(0)" onclick="changeStatus(${t.id}, 1)">Answered</a></li>
            <li><a class="dropdown-item" href="javascript:void(0)" onclick="changeStatus(${t.id}, 2)">Closed</a></li>
        </ul>
    </li>

    <li><hr class="dropdown-divider"></li>

    <li><a class="dropdown-item text-danger" href="javascript:void(0)" onclick="deleteTicket(${t.id})">Delete</a></li>

</ul>
                        </div>
                    </td>
                </tr>
            `).join('');
        }

        async function loadTickets() {
            const search = document.getElementById('ticketsSearch').value.trim();
            const field  = document.getElementById('searchField').value;

            document.getElementById('ticketsTableBody').innerHTML =
                `<tr><td colspan="7" class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></td></tr>`;

            try {
                const params = new URLSearchParams({
                    status: currentStatus,
                    page: currentPage,
                    pageSize,
                    search,
                    field
                });

                const res  = await fetch(`/admin/tickets/GetAll?${params}`);
                const data = await res.json();

                if (data.success) {
                    renderRows(data.data);
                    document.getElementById('totalCount').textContent = `Total: ${data.total}`;
                    renderPagination(data.total);
                }
            } catch (e) {
                document.getElementById('ticketsTableBody').innerHTML =
                    `<tr><td colspan="7" class="text-center py-4 text-danger">Failed to load tickets.</td></tr>`;
            }
        }

        function renderPagination(total) {
            const totalPages = Math.ceil(total / pageSize);
            const container = document.getElementById('paginationContainer');
            if (totalPages <= 1) { container.innerHTML = ''; return; }

            let html = '';
            const start = Math.max(1, currentPage - 2);
            const end   = Math.min(totalPages, currentPage + 2);

            if (currentPage > 1)
                html += `<button class="btn btn-sm btn-outline-secondary" onclick="goPage(${currentPage - 1})">‹</button>`;

            for (let i = start; i <= end; i++)
                html += `<button class="btn btn-sm ${i === currentPage ? 'btn-primary' : 'btn-outline-secondary'}" onclick="goPage(${i})">${i}</button>`;

            if (currentPage < totalPages)
                html += `<button class="btn btn-sm btn-outline-secondary" onclick="goPage(${currentPage + 1})">›</button>`;

            container.innerHTML = html;
        }

        function goPage(page) {
            currentPage = page;
            loadTickets();
        }

        document.getElementById('statusTabs').addEventListener('click', function (e) {
            const btn = e.target.closest('.status-tab-btn');
            if (!btn) return;

            document.querySelectorAll('.status-tab-btn').forEach(b => {
                b.classList.remove('btn-primary');
                b.classList.add('btn-outline-secondary');
            });
            btn.classList.add('btn-primary');
            btn.classList.remove('btn-outline-secondary');

            currentStatus = btn.dataset.status;
            currentPage   = 1;
            loadTickets();
        });

        // ── Actions ──────────────────────────────────────────────
        function ticketDetails(id) { setModalSize('lg'); openDynamicModal(`/admin/tickets/Details/${id}`); }
        function newTicket()       { setModalSize('');   openDynamicModal(`/admin/tickets/Create`); }

        async function changeStatus(id, status) {
            const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
            await fetch('/admin/tickets/ChangeStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token },
                body: JSON.stringify({ id, status })
            });
            loadTickets();
        }

        // ── Promise tabanlı modal confirm ──────────────────────────────
        // confirm() yerine kullanılır: const ok = await confirmModal('Title', 'Message');
        function confirmModal(title, message) {
        return new Promise((resolve) => {
        const modalEl = document.getElementById('confirmModal');
        const modal = new bootstrap.Modal(modalEl);
        const confirmBtn = document.getElementById('confirmModalConfirmBtn');

        document.getElementById('confirmModalTitle').textContent = title;
        document.getElementById('confirmModalBody').textContent = message;

        let resolved = false;

        const onConfirm = () => {
        resolved = true;
        modal.hide();
        resolve(true);
        };

        const onHidden = () => {
        confirmBtn.removeEventListener('click', onConfirm);
        modalEl.removeEventListener('hidden.bs.modal', onHidden);
        if (!resolved) resolve(false);
        };

        confirmBtn.addEventListener('click', onConfirm);
        modalEl.addEventListener('hidden.bs.modal', onHidden);

        modal.show();
        });
        }

        // ── Delete Ticket ────────────────────────────────────────────
        async function deleteTicket(id) {
        const ok = await confirmModal('Delete Ticket', 'Are you sure you want to delete this ticket? This action cannot be undone.');
        if (!ok) return;

        try {
        const token = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') ?? '';

        const res = await fetch('/admin/tickets/DeleteTicket', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token },
        body: JSON.stringify({ id })
        });

        const result = await res.json();

        if (result.success) {
        loadTickets();
        } else {
        alert(result.message || 'Failed to delete ticket.');
        }
        } catch (err) {
        alert('Connection error.');
        console.error(err);
        }
        }

        function exportTickets() {
            const status = currentStatus === 'All' ? '' : currentStatus;
            window.location.href = `/admin/tickets/Export?status=${status}`;
        }

        // ── New Ticket Modal Handler (delegated) ──────────────────
        document.addEventListener('click', async function (e) {
            if (e.target.id !== 'btnNewTicket' && !e.target.closest('#btnNewTicket')) return;

            const btn      = document.getElementById('btnNewTicket');
            const userId   = document.getElementById('auUserId');
            const subject  = document.getElementById('auSubject');
            const message  = document.getElementById('auMessage');
            const alertBox = document.getElementById('addUserAlert');

            userId.classList.remove('is-invalid');
            subject.classList.remove('is-invalid');
            message.classList.remove('is-invalid');

            if (!userId.value.trim())  { userId.classList.add('is-invalid');  return; }
            if (!subject.value.trim()) { subject.classList.add('is-invalid'); return; }
            if (!message.value.trim()) { message.classList.add('is-invalid'); return; }

            document.getElementById('btnNewTicketText').classList.add('d-none');
            document.getElementById('btnNewTicketSpinner').classList.remove('d-none');
            btn.disabled = true;

            try {
                const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

                const res = await fetch('/admin/tickets/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token },
                    body: JSON.stringify({
                        userId: parseInt(userId.value.trim()),
                        subject: subject.value.trim(),
                        message: message.value.trim()
                    })
                });

                const result = await res.json();

                if (result.success) {
                    alertBox.innerHTML = `<div class="alert alert-success py-2"><i class="fas fa-check-circle me-2"></i>Ticket created successfully.</div>`;
                    loadTickets();
                    setTimeout(() => bootstrap.Modal.getInstance(document.getElementById('dynamicModal'))?.hide(), 1200);
                } else {
                    alertBox.innerHTML = `<div class="alert alert-danger py-2">${result.message}</div>`;
                }
            } catch (error) {
                alertBox.innerHTML = `<div class="alert alert-danger py-2">Connection error.</div>`;
                console.error('Fetch error:', error);
            } finally {
                document.getElementById('btnNewTicketText').classList.remove('d-none');
                document.getElementById('btnNewTicketSpinner').classList.add('d-none');
                btn.disabled = false;
            }
        });


        document.querySelectorAll('.dropdown-submenu > a').forEach(el => {
        el.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        const submenu = this.nextElementSibling;
        submenu.style.display = submenu.style.display === 'block' ? 'none' : 'block';
        });
        });

        // ── Send Reply (from Ticket Details modal) ────────────────
        async function sendReply(ticketId) {
            const textarea = document.getElementById('replyMessage');
            const alertBox = document.getElementById('replyAlert');
            const btn      = document.getElementById('btnSendReply');

            const message = textarea.value.trim();
            if (!message) {
                textarea.classList.add('is-invalid');
                return;
            }
            textarea.classList.remove('is-invalid');

            document.getElementById('btnSendReplyText').classList.add('d-none');
            document.getElementById('btnSendReplySpinner').classList.remove('d-none');
            btn.disabled = true;

            try {
                const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

                const res = await fetch('/admin/tickets/Reply', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token },
                    body: JSON.stringify({ ticketId, message })
                });

                const result = await res.json();

                if (result.success) {
                    // Reload modal content to show new message
                    ticketDetails(ticketId);
                    loadTickets();
                } else {
                    alertBox.innerHTML = `<div class="alert alert-danger py-2 mb-2">${result.message}</div>`;
                }
            } catch (error) {
                alertBox.innerHTML = `<div class="alert alert-danger py-2 mb-2">Connection error.</div>`;
                console.error('Fetch error:', error);
            } finally {
                document.getElementById('btnSendReplyText')?.classList.remove('d-none');
                document.getElementById('btnSendReplySpinner')?.classList.add('d-none');
                if (btn) btn.disabled = false;
            }
        }

        // ── Init ─────────────────────────────────────────────────
        loadTickets();

        document.getElementById('ticketsSearch').addEventListener('keydown', function (e) {
            if (e.key === 'Enter') loadTickets();
        });

    </script>
}
