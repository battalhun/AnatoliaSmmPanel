@model AnatoliaSmmPanel.Areas.Admin.ViewModels.Tickets.NewTicketViewModel

<div class="modal-header bg-body-tertiary py-3">
    <h5 class="modal-title fw-bold">
        <i class="fas fa-ticket-alt me-2 text-primary"></i>New Ticket
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body p-4">
    <div id="addUserAlert"></div>

    <div class="row g-3 mb-3">
        <div class="col-md-12">
            <label class="form-label fw-semibold">User Id <span class="text-danger">*</span></label>
            <input id="auUserId" type="number" class="form-control bg-body" placeholder="e.g. 123">
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-6">
            <label class="form-label fw-semibold">Subject <span class="text-danger">*</span></label>
            <input id="auSubject" class="form-control bg-body">
        </div>
        <div class="col-md-6">
            <label class="form-label fw-semibold">Message <span class="text-danger">*</span></label>
            <input type="text" id="auMessage" class="form-control bg-body">
        </div>
    </div>

</div>

<div class="modal-footer bg-body-tertiary p-3">
    <button type="button" class="btn btn-link text-secondary" data-bs-dismiss="modal">Cancel</button>
    <button type="button" id="btnNewTicket" class="btn btn-primary px-5">
        <span id="btnNewTicketText"><i class="fas fa-ticket-alt me-2"></i>Create Ticket</span>
        <span id="btnNewTicketSpinner" class="d-none">
            <span class="spinner-border spinner-border-sm me-2"></span>Creating...
        </span>
    </button>
</div>
