@model AnatoliaSmmPanel.Areas.Admin.ViewModels.Users.SetDiscountViewModel

<div class="modal-header bg-body-tertiary py-3">
    <h5 class="modal-title fw-bold">
        <i class="fas fa-percent me-2 text-info"></i>Set Discount
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body p-4">
    <div id="setDiscountAlert"></div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Discount %</label>
        <div class="input-group">
            <input type="number" id="discountPercent" class="form-control bg-body"
                   min="0" max="100" step="0.01"
                   value="@Model.DiscountPercent.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)">
            <span class="input-group-text bg-body">%</span>
        </div>
        <div class="form-text text-muted">0 = no discount, 100 = free</div>
    </div>

    <input type="hidden" id="sdUserId" value="@Model.UserId">
</div>

<div class="modal-footer bg-body-tertiary p-3">
    <button type="button" class="btn btn-link text-secondary" data-bs-dismiss="modal">Cancel</button>
    <button type="button" id="btnSetDiscount" class="btn btn-info px-5 text-white">
        <i class="fas fa-save me-2"></i>Save Discount
    </button>
</div>

<script>
    (function () {
        document.getElementById('btnSetDiscount').addEventListener('click', async function () {
            const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
            const res = await fetch('/admin/users/SetDiscount', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token },
                body: JSON.stringify({
                    userId: parseInt(document.getElementById('sdUserId').value),
                    discountPercent: parseFloat(document.getElementById('discountPercent').value) || 0
                })
            });
            const result = await res.json();
            if (result.success) {
                document.getElementById('setDiscountAlert').innerHTML =
                    `<div class="alert alert-success py-2"><i class="fas fa-check-circle me-2"></i>Discount saved.</div>`;
                setTimeout(() => bootstrap.Modal.getInstance(document.getElementById('dynamicModal'))?.hide(), 1200);
            } else {
                document.getElementById('setDiscountAlert').innerHTML =
                    `<div class="alert alert-danger py-2">${result.message}</div>`;
            }
        });
    })();
</script>