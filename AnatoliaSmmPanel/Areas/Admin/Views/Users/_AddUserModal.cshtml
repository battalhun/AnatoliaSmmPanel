@model AnatoliaSmmPanel.Areas.Admin.ViewModels.Users.AddUserViewModel

<div class="modal-header bg-body-tertiary py-3">
    <h5 class="modal-title fw-bold">
        <i class="fas fa-user-plus me-2 text-primary"></i>Add User
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body p-4">
    <div id="addUserAlert"></div>

    <div class="row g-3 mb-3">
        <div class="col-md-6">
            <label class="form-label fw-semibold">Username</label>
            <input type="text" id="auNickname" class="form-control bg-body" maxlength="50">
        </div>
        <div class="col-md-6">
            <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
            <input type="email" id="auEmail" class="form-control bg-body">
            <div class="invalid-feedback">Valid email is required.</div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-6">
            <label class="form-label fw-semibold">Password <span class="text-danger">*</span></label>
            <input type="password" id="auPassword" class="form-control bg-body">
            <div class="invalid-feedback">Password is required.</div>
        </div>
        <div class="col-md-6">
            <label class="form-label fw-semibold">Phone</label>
            <input type="text" id="auPhone" class="form-control bg-body">
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-md-6">
            <label class="form-label fw-semibold">Status</label>
            <select id="auStatus" class="form-select bg-body">
                <option value="Active">Active</option>
                <option value="Suspended">Suspended</option>
                <option value="Unconfirmed">Unconfirmed</option>
            </select>
        </div>
        <div class="col-md-6">
            <label class="form-label fw-semibold">Balance (USD)</label>
            <div class="input-group">
                <span class="input-group-text bg-body">$</span>
                <input type="number" id="auBalance" class="form-control bg-body" value="0" step="0.01" min="0">
            </div>
        </div>
    </div>
</div>

<div class="modal-footer bg-body-tertiary p-3">
    <button type="button" class="btn btn-link text-secondary" data-bs-dismiss="modal">Cancel</button>
    <button type="button" id="btnAddUser" class="btn btn-primary px-5">
        <span id="btnAddUserText"><i class="fas fa-user-plus me-2"></i>Add User</span>
        <span id="btnAddUserSpinner" class="d-none">
            <span class="spinner-border spinner-border-sm me-2"></span>Adding...
        </span>
    </button>
</div>

<script>
    (function () {
        document.getElementById('btnAddUser').addEventListener('click', async function () {
            const email = document.getElementById('auEmail');
            const pwd = document.getElementById('auPassword');

            email.classList.remove('is-invalid');
            pwd.classList.remove('is-invalid');

            if (!email.value.trim()) { email.classList.add('is-invalid'); return; }
            if (!pwd.value) { pwd.classList.add('is-invalid'); return; }

            document.getElementById('btnAddUserText').classList.add('d-none');
            document.getElementById('btnAddUserSpinner').classList.remove('d-none');
            document.getElementById('btnAddUser').disabled = true;

            try {
                const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
                const res = await fetch('/admin/users/AddUser', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token },
                    body: JSON.stringify({
                        nickname: document.getElementById('auNickname').value.trim(),
                        email: email.value.trim(),
                        password: pwd.value,
                        phoneNumber: document.getElementById('auPhone').value.trim(),
                        status: document.getElementById('auStatus').value,
                        balance: parseFloat(document.getElementById('auBalance').value) || 0
                    })
                });
                const result = await res.json();
                if (result.success) {
                    document.getElementById('addUserAlert').innerHTML =
                        `<div class="alert alert-success py-2"><i class="fas fa-check-circle me-2"></i>User created successfully.</div>`;
                    setTimeout(() => bootstrap.Modal.getInstance(document.getElementById('dynamicModal'))?.hide(), 1200);
                } else {
                    document.getElementById('addUserAlert').innerHTML =
                        `<div class="alert alert-danger py-2">${result.message}</div>`;
                }
            } catch {
                document.getElementById('addUserAlert').innerHTML =
                    `<div class="alert alert-danger py-2">Connection error.</div>`;
            } finally {
                document.getElementById('btnAddUserText').classList.remove('d-none');
                document.getElementById('btnAddUserSpinner').classList.add('d-none');
                document.getElementById('btnAddUser').disabled = false;
            }
        });
    })();
</script>