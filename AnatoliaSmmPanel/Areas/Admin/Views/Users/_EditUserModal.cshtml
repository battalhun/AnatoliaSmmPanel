@model AnatoliaSmmPanel.Data.Models.Appliciton.ApplicationUser

@Html.AntiForgeryToken()

<div class="modal-header bg-body-tertiary py-3">
    <h5 class="modal-title fw-bold">
        <i class="fas fa-user-edit me-2 text-primary"></i>
        Edit User
        <span class="badge bg-secondary ms-2 fw-normal fs-6">
            ID: (@Model.UserId)
        </span>
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body p-4">

    <div id="editUserAlert"></div>

    <form id="editUserForm">

        <div class="row g-3 mb-3">

            <!-- NICKNAME -->
            <div class="col-md-6">
                <label for="editUserNickname" class="form-label fw-semibold">Username</label>
                <input type="text"
                       id="editUserNickname"
                       class="form-control bg-body"
                       maxlength="50"
                       value="@Model.Nickname">
            </div>

            <!-- EMAIL -->
            <div class="col-md-6">
                <label for="editUserEmail" class="form-label fw-semibold">
                    Email <span class="text-danger">*</span>
                </label>
                <input type="email"
                       id="editUserEmail"
                       class="form-control bg-body"
                       value="@Model.Email"
                       required>
                <div class="invalid-feedback">Valid email is required.</div>
            </div>

        </div>

        <div class="row g-3 mb-3">

            <!-- PHONE -->
            <div class="col-md-6">
                <label for="editUserPhone" class="form-label fw-semibold">Phone</label>
                <input type="text"
                       id="editUserPhone"
                       class="form-control bg-body"
                       value="@Model.PhoneNumber">
            </div>

            <!-- STATUS -->
            <div class="col-md-6">
                <label for="editUserStatus" class="form-label fw-semibold">Status</label>
                <select id="editUserStatus" class="form-select bg-body">
                    <option value="Active" selected="@(Model.Status == "Active")">Active</option>
<option value="Suspended" selected="@(Model.Status == "Suspended")">Suspended</option>
<option value="Unconfirmed" selected="@(Model.Status == "Unconfirmed")">Unconfirmed</option>
<option value="Malicious" selected="@(Model.Status == "Malicious")">Malicious</option>
                </select>
            </div>

        </div>

        <div class="row g-3 mb-3">

            <!-- BALANCE -->
            <div class="col-md-6">
                <label for="editUserBalance" class="form-label fw-semibold">
                    Balance <span class="text-muted fw-normal">(USD)</span>
                </label>
                <div class="input-group">
                    <span class="input-group-text bg-body">$</span>
                    <input type="number"
                           id="editUserBalance"
                           class="form-control bg-body"
                           step="0.01"
                           min="0"
                           value="@Model.Balance.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)">
                </div>
            </div>

            <!-- SPENT (readonly) -->
            <div class="col-md-6">
                <label for="editUserSpent" class="form-label fw-semibold">
                    Spent <span class="text-muted fw-normal">(USD)</span>
                </label>
                <div class="input-group">
                    <span class="input-group-text bg-body">$</span>
                    <input type="number"
                           id="editUserSpent"
                           class="form-control bg-body"
                           step="0.01"
                           min="0"
                           value="@Model.Spent.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)">
                </div>
            </div>

        </div>

        <!-- FLAGS -->
        <div class="p-3 rounded border bg-body-secondary mb-3">
            <div class="fw-semibold small text-uppercase text-muted mb-3">Account Flags</div>
            <div class="row g-2">
                <div class="col-md-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox"
                               id="editUserEmailConfirmed"
                               @(Model.EmailConfirmed ? "checked" : "")>
                        <label class="form-check-label" for="editUserEmailConfirmed">
                            <i class="fas fa-envelope me-1 text-success"></i> Email Confirmed
                        </label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox"
                               id="editUserPhoneConfirmed"
                               @(Model.PhoneNumberConfirmed ? "checked" : "")>
                        <label class="form-check-label" for="editUserPhoneConfirmed">
                            <i class="fas fa-phone me-1 text-info"></i> Phone Confirmed
                        </label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox"
                               id="editUserTwoFactor"
                               @(Model.TwoFactorEnabled ? "checked" : "")>
                        <label class="form-check-label" for="editUserTwoFactor">
                            <i class="fas fa-shield-alt me-1 text-warning"></i> Two Factor
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <input type="hidden" id="editUserId" value="@Model.UserId">

    </form>

</div>

<div class="modal-footer bg-body-tertiary p-3">
    <button type="button"
            class="btn btn-link text-decoration-none text-secondary"
            data-bs-dismiss="modal">
        Cancel
    </button>
    <button type="button"
            id="btnSaveUser"
            class="btn btn-primary px-5 shadow-sm">
        <span id="btnSaveUserText">
            <i class="fas fa-save me-2"></i>Save Changes
        </span>
        <span id="btnSaveUserSpinner" class="d-none">
            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            Saving...
        </span>
    </button>
</div>

<script>
(function () {

    document.getElementById('btnSaveUser').addEventListener('click', async function () {

        const emailInput = document.getElementById('editUserEmail');
        if (!emailInput.value.trim()) {
            emailInput.classList.add('is-invalid');
            return;
        }
        emailInput.classList.remove('is-invalid');

        const payload = {
            id:                   parseInt(document.getElementById('editUserId').value),
            nickname:             document.getElementById('editUserNickname').value.trim(),
            email:                document.getElementById('editUserEmail').value.trim(),
            phoneNumber:          document.getElementById('editUserPhone').value.trim(),
            status:               document.getElementById('editUserStatus').value,
            balance:              parseFloat(document.getElementById('editUserBalance').value) || 0,
            spent:                parseFloat(document.getElementById('editUserSpent').value) || 0,
            emailConfirmed:       document.getElementById('editUserEmailConfirmed').checked,
            phoneNumberConfirmed: document.getElementById('editUserPhoneConfirmed').checked,
            twoFactorEnabled:     document.getElementById('editUserTwoFactor').checked,
        };

        document.getElementById('btnSaveUserText').classList.add('d-none');
        document.getElementById('btnSaveUserSpinner').classList.remove('d-none');
        document.getElementById('btnSaveUser').disabled = true;

        try {
            const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

            const response = await fetch('/admin/users/UpdateUser', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-TOKEN': token
                },
                body: JSON.stringify(payload)
            });

            const result = await response.json();

            if (result.success) {
                document.getElementById('editUserAlert').innerHTML = `
                    <div class="alert alert-success d-flex align-items-center gap-2 py-2">
                        <i class="fas fa-check-circle"></i>
                        User updated successfully.
                    </div>`;

                setTimeout(() => {
                    bootstrap.Modal.getInstance(document.getElementById('dynamicModal'))?.hide();
                }, 1200);

            } else {
                document.getElementById('editUserAlert').innerHTML = `
                    <div class="alert alert-danger d-flex align-items-center gap-2 py-2">
                        <i class="fas fa-exclamation-circle"></i>
                        ${result.message || 'An error occurred.'}
                    </div>`;
            }

        } catch (err) {
            document.getElementById('editUserAlert').innerHTML = `
                <div class="alert alert-danger py-2">
                    <i class="fas fa-exclamation-circle me-2"></i>Connection error.
                </div>`;
        } finally {
            document.getElementById('btnSaveUserText').classList.remove('d-none');
            document.getElementById('btnSaveUserSpinner').classList.add('d-none');
            document.getElementById('btnSaveUser').disabled = false;
        }
    });

})();
</script>
