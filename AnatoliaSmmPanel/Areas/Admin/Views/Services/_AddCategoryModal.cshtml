@model AnatoliaSmmPanel.Areas.Admin.ViewModels.Services.CreateCategoryViewModel

@Html.AntiForgeryToken()

<div class="modal-header bg-body-tertiary py-3">
    <h5 class="modal-title fw-bold">
        <i class="fas fa-folder-plus me-2 text-primary"></i>Create Category
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body p-4">

    <div id="addCategoryAlert"></div>

    <div class="mb-3">
        <label for="categoryName" class="form-label fw-semibold">
            Category Name <span class="text-danger">*</span>
        </label>
        <input type="text"
               id="categoryName"
               class="form-control bg-body"
               placeholder="e.g. Instagram, YouTube..."
               maxlength="100"
               autofocus>
        <div class="invalid-feedback">Category name is required.</div>
    </div>

    <div class="mb-3">
        <label for="categorySortOrder" class="form-label fw-semibold">Sort Order</label>
        <input type="number"
               id="categorySortOrder"
               class="form-control bg-body"
               value="0"
               min="0">
        <div class="form-text text-muted">Lower numbers appear first.</div>
    </div>

    <div class="mb-3">
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" id="categoryIsActive" checked>
            <label class="form-check-label fw-semibold" for="categoryIsActive">Active</label>
        </div>
    </div>

</div>

<div class="modal-footer bg-body-tertiary p-3">
    <button type="button"
            class="btn btn-link text-decoration-none text-secondary"
            data-bs-dismiss="modal">
        Cancel
    </button>
    <button type="button"
            id="btnSaveCategory"
            class="btn btn-primary px-5 shadow-sm">
        <span id="btnSaveCategoryText">
            <i class="fas fa-save me-2"></i>Save Category
        </span>
        <span id="btnSaveCategorySpinner" class="d-none">
            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            Saving...
        </span>
    </button>
</div>

<script>
    (function () {
        document.getElementById('btnSaveCategory').addEventListener('click', async function () {

            const nameInput = document.getElementById('categoryName');
            const name = nameInput.value.trim();

            // Validation
            if (!name) {
                nameInput.classList.add('is-invalid');
                return;
            }
            nameInput.classList.remove('is-invalid');

            const payload = {
                name: name,
                sortOrder: parseInt(document.getElementById('categorySortOrder').value) || 0,
                isActive: document.getElementById('categoryIsActive').checked
            };

            // Loading state
            document.getElementById('btnSaveCategoryText').classList.add('d-none');
            document.getElementById('btnSaveCategorySpinner').classList.remove('d-none');
            document.getElementById('btnSaveCategory').disabled = true;

            try {
               const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');

                const response = await fetch('/admin/services/CreateCategory', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': token
                    },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();

                if (result.success) {
                    document.getElementById('addCategoryAlert').innerHTML = `
                        <div class="alert alert-success d-flex align-items-center gap-2 py-2">
                            <i class="fas fa-check-circle"></i>
                            Category <strong>${result.name}</strong> created successfully.
                        </div>`;

                    // Formu temizle
                    nameInput.value = '';
                    document.getElementById('categorySortOrder').value = '0';
                    document.getElementById('categoryIsActive').checked = true;

                    // Redux store varsa dispatch et
                    if (typeof store !== 'undefined') {
                        store.dispatch({ type: 'RELOAD_SERVICES' });
                    }

                    setTimeout(() => {
                        bootstrap.Modal.getInstance(document.getElementById('dynamicModal'))?.hide();
                    }, 1200);

                } else {
                    document.getElementById('addCategoryAlert').innerHTML = `
                        <div class="alert alert-danger d-flex align-items-center gap-2 py-2">
                            <i class="fas fa-exclamation-circle"></i>
                            ${result.message || 'An error occurred.'}
                        </div>`;
                }

            } catch (err) {
                document.getElementById('addCategoryAlert').innerHTML = `
                    <div class="alert alert-danger py-2">
                        <i class="fas fa-exclamation-circle me-2"></i>Connection error.
                    </div>`;
            } finally {
                document.getElementById('btnSaveCategoryText').classList.remove('d-none');
                document.getElementById('btnSaveCategorySpinner').classList.add('d-none');
                document.getElementById('btnSaveCategory').disabled = false;
            }
        });

        // Name input enter key
        document.getElementById('categoryName').addEventListener('keydown', function (e) {
            if (e.key === 'Enter') document.getElementById('btnSaveCategory').click();
        });
    })();
</script>