@using AnatoliaSmmPanel.Areas.Admin.ViewModels.Services.Import
@model ImportViewModel

@section Styles {
    <link href="~/css/_data_table.css" rel="stylesheet" />
}

<style>
    /* ============================= */
    /* AG GRID PROFESSIONAL UI FIX   */
    /* ============================= */

    #agGridWrapper {
        flex: 1 1 auto;
        overflow: hidden;
        min-height: 0;
    }

    #myGrid {
        height: 100%;
        width: 100%;
    }

    /* Genel tema */
    .ag-theme-alpine {
        --ag-font-size: 13px;
        --ag-font-family: Inter, sans-serif;
        --ag-border-color: #e9ecef;
        --ag-row-border-color: #f1f3f5;
        --ag-header-background-color: #ffffff;
        --ag-odd-row-background-color: #fcfcfd;
        --ag-row-hover-color: rgba(13, 110, 253, 0.04);
        --ag-selected-row-background-color: rgba(13, 110, 253, 0.06);
        border: 1px solid #e9ecef;
        border-radius: 12px;
        overflow: hidden;
    }

        /* Header alanı */
        .ag-theme-alpine .ag-header {
            background: #ffffff !important;
            border-bottom: 1px solid #e9ecef !important;
            min-height: 52px !important;
        }

        /* Sütun başlıkları */
        .ag-theme-alpine .ag-header-cell {
            border-right: 1px solid #f1f3f5;
            padding: 0 12px;
        }

            .ag-theme-alpine .ag-header-cell:last-child {
                border-right: none;
            }

        .ag-theme-alpine .ag-header-cell-label {
            font-size: 13px;
            font-weight: 700;
            color: #212529;
            letter-spacing: 0.2px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* Header menüsündeki 3 nokta kaldır */
        .ag-theme-alpine .ag-header-cell-menu-button {
            display: none !important;
        }

        /* Filter ikonunu kaldır */
        .ag-theme-alpine .ag-header-icon.ag-header-label-icon.ag-filter-icon {
            display: none !important;
        }

        /* Sort ikonlarını sadeleştir */
        .ag-theme-alpine .ag-sort-indicator-container {
            margin-left: auto;
            opacity: 0.6;
        }

        /* Resize çizgisi daha soft */
        .ag-theme-alpine .ag-header-cell-resize::after {
            background: #dee2e6 !important;
            width: 1px;
        }

        /* Satırlar */
        .ag-theme-alpine .ag-row {
            font-size: 13px;
            border-bottom: 1px solid #f8f9fa !important;
            transition: all 0.15s ease;
        }

            .ag-theme-alpine .ag-row:hover {
                background: rgba(13, 110, 253, 0.03) !important;
            }

        /* Group row (kategori satırı) */
        .ag-theme-alpine .ag-row-group {
            background: #f8f9fc !important;
            font-weight: 700;
            font-size: 13px;
            color: #212529;
            border-bottom: 1px solid #e9ecef !important;
        }

        /* Checkbox hizalama */
        .ag-theme-alpine .ag-checkbox-input-wrapper {
            transform: scale(0.95);
        }

 

    /* Actions dropdown */
    .ag-theme-alpine .btn-group .btn {
        border-radius: 8px !important;
        font-size: 12px;
        font-weight: 500;
    }

    /* Pagination / footer görünümü */
    .ag-theme-alpine .ag-paging-panel {
        border-top: 1px solid #e9ecef;
        background: #fff;
    }

    /* Focus border kaldır */
    .ag-theme-alpine .ag-cell-focus,
    .ag-theme-alpine .ag-cell-no-focus {
        border: none !important;
    }

    .ag-theme-alpine .ag-cell:focus {
        outline: none !important;
    }

    /* Sol pinned alan daha temiz */
    .ag-theme-alpine .ag-pinned-left-header,
    .ag-theme-alpine .ag-pinned-left-cols-container {
        border-right: 1px solid #f1f3f5;
    }

    /* Sağ pinned alan */
    .ag-theme-alpine .ag-pinned-right-header,
    .ag-theme-alpine .ag-pinned-right-cols-container {
        border-left: 1px solid #f1f3f5;
    }

  

    .ag-row-group .ag-group-expanded,
    .ag-row-group .ag-group-contracted {
        display: none !important;
    }



</style>

<div class="wrapper" id="page-wrapper">

    <div id="wrapper-alerts">
        <div class="wrapper-alerts"></div>
    </div>

    <div class="page">
        <div class="d-flex flex-column vh-100 bg-body-tertiary shadow-sm" style="padding: 10px; border-radius: 5px;">

            <!-- HEADER -->
            <header class="container-fluid py-4 border-bottom bg-body-tertiary">
                <div class="row align-items-center">
                    <div class="col-md-7">
                        <div class="d-flex flex-wrap gap-2 align-items-center">
                            <button id="add-service" class="btn btn-primary px-3">
                                <i class="fas fa-plus me-2"></i> Add Service
                            </button>
                            <button id="add-subscription" class="btn btn-outline-secondary px-3">Add Subscription</button>
                            <button id="create-category" class="btn btn-outline-secondary px-3">Create Category</button>
                            <button id="import-button" class="btn btn-outline-info px-3" onclick="importbutton()">
                                Import
                            </button>

                            <!-- Seçim yapılınca belirir -->
                            <div id="bulkActions" class="d-none d-flex gap-2 align-items-center ms-2 border-start ps-3">
                                <span class="text-muted small" id="selectedInfo"></span>
                                <button class="btn btn-sm btn-success" onclick="bulkSetActive(true)">Enable</button>
                                <button class="btn btn-sm btn-warning" onclick="bulkSetActive(false)">Disable</button>
                                <button class="btn btn-sm btn-outline-danger" onclick="bulkDelete()">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-5">
                        <div class="input-group">
                            <span class="input-group-text bg-body border-end-0">
                                <i class="fas fa-search text-muted"></i>
                            </span>
                            <input type="text" id="searchInput" class="form-control border-start-0 py-2 bg-body"
                                   placeholder="Search for services, IDs..."
                                   oninput="onSearch(this.value)">
                            <select id="searchField" class="form-select border-start-0 bg-body" style="max-width: 140px;">
                                <option value="all">All Fields</option>
                                <option value="name">Service Name</option>
                                <option value="id">ID</option>
                            </select>
                        </div>
                    </div>
                </div>
            </header>

            <!-- AG GRID -->
            <main class="flex-grow-1 d-flex flex-column overflow-hidden">
                <div id="agGridWrapper">
                    <div id="myGrid" class="ag-theme-alpine"></div>
                </div>
            </main>

            <!-- FOOTER -->
            <footer class="container-fluid py-3 border-top bg-body-tertiary">
                <div class="d-flex justify-content-between align-items-center">
                    <button type="button" class="btn btn-link btn-sm text-decoration-none text-secondary">
                        <i class="fas fa-trash-alt me-1"></i> Deleted Services
                    </button>
                    <div class="d-flex align-items-center gap-3">
                        <div id="loadingSpinner" class="spinner-border spinner-border-sm text-primary d-none" role="status"></div>
                        <span class="badge bg-secondary px-3 py-2" id="totalCount">Total: 0</span>
                    </div>
                </div>
            </footer>

        </div>
    </div>
</div>

<!-- Dinamik Modal -->
<div class="modal fade" id="dynamicModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow" id="dynamicModalBody">
            <div class="text-center p-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Yükleniyor...</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function importbutton() {
        setModalSize('xl');
        openDynamicModal('/admin/services/import');
    }
</script>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/redux/4.2.1/redux.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/ag-grid-enterprise/dist/ag-grid-enterprise.min.js"></script>

    <script>
      
        agGrid.LicenseManager.setLicenseKey('[TRIAL]_this_{AG_Charts_and_AG_Grid}_Enterprise_key_{AG-128628}_is_granted_for_evaluation_only___Use_in_production_is_not_permitted___Please_report_misuse_to_legal@ag-grid.com___For_help_with_purchasing_a_production_key_please_contact_info@ag-grid.com___You_are_granted_a_{Single_Application}_Developer_License_for_one_application_only___All_Front-End_JavaScript_developers_working_on_the_application_would_need_to_be_licensed___This_key_will_deactivate_on_{10 June 2026}____[v3]_[0102]_MTc4MTA0NjAwMDAwMA==27bf590b40f80de6d2c08a74090a07f7');

        /* =========================
        Yardımcılar
        ========================= */

        function statusBadge(val) {
        if (val === undefined || val === null) return '';

        return val
        ? '<span class="badge bg-success-subtle text-success border border-success-subtle">Enabled</span>'
        : '<span class="badge bg-danger-subtle text-danger border border-danger-subtle">Disabled</span>';
        }

        function iconFlags(data) {
        if (!data) return '';

        let icons = '';

        if (data.dripfeed)
        icons += '<i class="fas fa-tint me-1 text-primary"></i>';

        if (data.cancel)
        icons += '<i class="fas fa-times-circle me-1 text-danger"></i>';

        if (data.refill)
        icons += '<i class="fas fa-sync-alt me-1 text-warning"></i>';

        return icons;
        }

        /* =========================
        Columns
        ========================= */

        const columnDefs = [
        {
        width: 60,
        resizable: false,
        sortable: false,
        filter: false,
        pinned: 'left',

        headerCheckboxSelection: true,
        checkboxSelection: p => !!p.data,

        cellRenderer: () => ''
        },

        {
        field: 'id',
        headerName: 'ID',
        width: 80,
        cellRenderer: p => p.data ? `#${p.data.id}` : ''
        },

        {
        field: 'name',
        headerName: 'Service Name',
        flex: 2,
        editable: true,
        cellRenderer: p =>
        p.data
        ? `<div class="fw-bold text-truncate">${p.data.name}</div>`
        : ''
        },

        {
        field: 'type',
        headerName: 'Type',
        width: 150,
        cellRenderer: p =>
        p.data
        ? `<div class="small">${p.data.type || 'Default'}</div>${iconFlags(p.data)}`
        : ''
        },

        {
        headerName: 'Provider',
        width: 150,
        valueGetter: p =>
        p.data?.provider?.name || 'Manual'
        },

        {
        field: 'rate',
        headerName: 'Rate',
        width: 100,
        editable: true,
        cellRenderer: p =>
        p.data ? `<span class="fw-bold text-primary">${p.data.rate}</span>` : ''
        },

        {
        field: 'min',
        headerName: 'Min',
        width: 80
        },

        {
        field: 'max',
        headerName: 'Max',
        width: 80
        },

        {
        field: 'isActive',
        headerName: 'Status',
        width: 120,
        cellRenderer: p => p.data ? statusBadge(p.value) : ''
        },

        {
        headerName: 'Actions',
        width: 120,
        pinned: 'right',
        sortable: false,
        filter: false,
        resizable: false,

        cellRenderer: p => {
        if (!p.data) return '';

        return `
        <div class="dropdown">
        <button class="btn btn-sm btn-light border dropdown-toggle"
        data-bs-toggle="dropdown">
        Actions
        </button>

        <ul class="dropdown-menu dropdown-menu-end shadow">
        <li>
        <a class="dropdown-item"
        href="#"
        onclick="editService(${p.data.id})">
        Edit
        </a>
        </li>

        <li><hr class="dropdown-divider"></li>

        <li>
        <a class="dropdown-item text-danger"
        href="#"
        onclick="deleteService(${p.data.id})">
        Delete
        </a>
        </li>
        </ul>
        </div>
        `;
        }
        },

        {
        headerName: '_category',
        rowGroup: true,
        hide: true,
        valueGetter: p =>
        p.data?.serviceCategory?.name || 'Uncategorized'
        }
        ];

        /* =========================
        GRID OPTIONS (DRAGSIZ)
        ========================= */

        const gridOptions = {
        theme: 'legacy',
        columnDefs,
        rowData: [],

        /* GROUP */
        groupDisplayType: 'groupRows',
        groupDefaultExpanded: -1,
        rememberGroupStateWhenNewData: true,

        groupClickEdit: false, // opsiyonel
        // Satıra tıklandığında genişlemesi için:
        onRowClicked: (params) => {
        if (params.node.group) {
        params.node.setExpanded(!params.node.expanded);
        }
        },

        /* SELECTION */
        rowSelection: 'multiple',
        suppressRowClickSelection: true,
        groupSelectsChildren: true,

        groupRowRenderer: 'agGroupCellRenderer',
        groupRowRendererParams: {   
        checkbox: true,
        suppressCount: false,
        innerRenderer: p => `
        <div class="d-flex align-items-center gap-2">
        <i class="fas fa-folder text-warning"></i>
        <span class="fw-bold">${p.value}</span>
        </div>
        `
        },

        defaultColDef: {
        sortable: true,
        filter: true,
        resizable: true,
        suppressMenu: true
        },

        onSelectionChanged,

        onCellValueChanged: e => {
        if (!e.data) return;
        console.log('Updated:', e.data);
        }
        };

        /* =========================
        INIT GRID
        ========================= */

        const gridDiv = document.getElementById('myGrid');
        const grid = agGrid.createGrid(gridDiv, gridOptions);

        /* =========================
        SELECTION
        ========================= */

        function onSelectionChanged() {
        const count = grid.getSelectedRows().length;

        if (count > 0) {
        document.getElementById('selectedInfo').textContent = count + ' selected';
        document.getElementById('bulkActions').classList.remove('d-none');
        document.getElementById('bulkActions').classList.add('d-flex');
        } else {
        document.getElementById('bulkActions').classList.add('d-none');
        document.getElementById('bulkActions').classList.remove('d-flex');
        }
        }

        /* =========================
        BULK ACTIONS
        ========================= */

        function bulkSetActive(isActive) {
        const selected = grid.getSelectedRows();

        selected.forEach(r => r.isActive = isActive);

        grid.applyTransaction({ update: selected });
        }

        function bulkDelete() {
        const selected = grid.getSelectedRows();

        if (!confirm(selected.length + ' kaydı silinsin mi?')) return;

        grid.applyTransaction({ remove: selected });
        }

        /* =========================
        SEARCH
        ========================= */

        function onSearch(val) {
        const field = document.getElementById('searchField').value;

        if (field === 'all') {
        grid.setGridOption('quickFilterText', val);
        grid.setFilterModel(null);
        } else {
        grid.setGridOption('quickFilterText', '');

        grid.setFilterModel({
        [field]: {
        filterType: 'text',
        type: 'contains',
        filter: val
        }
        });
        }
        }

        /* =========================
        ACTIONS
        ========================= */

        function editService(id) {
        console.log('Edit:', id);
        }

        function deleteService(id) {
        console.log('Delete:', id);
        }

        /* =========================
        LOAD DATA
        ========================= */

        async function loadData() {
        document.getElementById('loadingSpinner').classList.remove('d-none');

        try {
        const res = await fetch('/admin/services/GetReduxAll');
        const json = await res.json();

        if (json.success) {
        grid.setGridOption('rowData', json.data);
        document.getElementById('totalCount').textContent = 'Total: ' + json.total;
        }
        } catch (err) {
        console.error(err);
        } finally {
        document.getElementById('loadingSpinner').classList.add('d-none');
        }
        }

        loadData();

        /* =========================
        BOOTSTRAP DROPDOWN FIX
        ========================= */

        grid.addEventListener('firstDataRendered', () => {
        document.querySelectorAll('[data-bs-toggle="dropdown"]').forEach(el => {
        bootstrap.Dropdown.getOrCreateInstance(el);
        });
        });

    </script>

    <script src="~/js/services/importservicesmodal.js"></script>
}
