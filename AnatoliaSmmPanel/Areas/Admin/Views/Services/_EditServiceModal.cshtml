@model AnatoliaSmmPanel.Areas.Admin.ViewModels.Services.EditServiceViewModel@inject AnatoliaSmmPanel.Data.ApplicationDbContext Context@Html.AntiForgeryToken()<div class="modal-header bg-body-tertiary py-3">    <h5 class="modal-title fw-bold">        <i class="fas fa-edit me-2 text-primary"></i>        Edit Service        <span class="badge bg-secondary ms-2 fw-normal fs-6">            ID: (@Model.Id)        </span>    </h5>    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body p-4">    <div id="editServiceAlert"></div>    <form id="editServiceForm">        <!-- SERVICE NAME -->        <div class="mb-3">            <label for="editServiceName" class="form-label fw-semibold">                Service Name <span class="text-danger">*</span>            </label>            <input type="text"                   id="editServiceName"                   name="name"                   class="form-control bg-body"                   maxlength="250"                   value="@Model.Name"                   required>            <div class="invalid-feedback">Service name is required.</div>        </div>        <div class="row g-3 mb-3">            <!-- CATEGORY -->            <div class="col-md-6">                <label for="editServiceCategory" class="form-label fw-semibold">Category</label>                <select id="editServiceCategory" name="serviceCategoryId" class="form-select bg-body">                    <option value="">— No Category —</option>                    @foreach (var cat in Context.ServiceCategories.Where(x => x.IsActive).OrderBy(x => x.SortOrder))                    {                        <option value="@cat.Id" selected="@(Model.ServiceCategoryId == cat.Id)">                            @cat.Name                        </option>                    }                </select>            </div>            <!-- PROVIDER -->            <div class="col-md-6">                <label for="editServiceProvider" class="form-label fw-semibold">Provider</label>                <select id="editServiceProvider" name="providerId" class="form-select bg-body">                    <option value="">— Manual —</option>                    @foreach (var prov in Context.Providers.Where(x => x.IsActive).OrderBy(x => x.Name))                    {                        <option value="@prov.Id" selected="@(Model.ProviderId == prov.Id)">                            @prov.Name                        </option>                    }                </select>            </div>        </div>        <div class="row g-3 mb-3">            <!-- TYPE -->            <div class="col-md-4">                <label for="editServiceType" class="form-label fw-semibold">Type</label>                <input type="text"                       id="editServiceType"                       name="type"                       class="form-control bg-body"                       placeholder="Default"                       maxlength="50"                       value="@Model.Type">            </div>            <!-- RATE -->            <div class="col-md-4">                <label for="editServiceRate" class="form-label fw-semibold">                    Rate per 1000 <span class="text-muted fw-normal">(USD)</span>                </label>                <div class="input-group">                    <span class="input-group-text bg-body">$</span>                    <input type="number"                           id="editServiceRate"                           name="rate"                           class="form-control bg-body"                           step="0.0001"                           min="0"                           value="@Model.Rate.ToString("0.0000", System.Globalization.CultureInfo.InvariantCulture)"                           required>                </div>            </div>            <!-- SORT ORDER -->            <div class="col-md-4">                <label for="editServiceSortOrder" class="form-label fw-semibold">Sort Order</label>                <input type="number"                       id="editServiceSortOrder"                       name="sortOrder"                       class="form-control bg-body"                       min="0"                       value="@Model.SortOrder">            </div>        </div>        <div class="row g-3 mb-3">            <!-- MIN -->            <div class="col-md-6">                <label for="editServiceMin" class="form-label fw-semibold">Min Order</label>                <input type="number"                       id="editServiceMin"                       name="min"                       class="form-control bg-body"                       min="1"                       value="@Model.Min"                       required>            </div>            <!-- MAX -->            <div class="col-md-6">                <label for="editServiceMax" class="form-label fw-semibold">Max Order</label>                <input type="number"                       id="editServiceMax"                       name="max"                       class="form-control bg-body"                       min="1"                       value="@Model.Max"                       required>            </div>        </div>        <!-- FEATURES -->        <div class="p-3 rounded border bg-body-secondary mb-3">            <div class="fw-semibold small text-uppercase text-muted mb-3">Features</div>            <div class="row g-2">                <div class="col-md-4">                    <div class="form-check form-switch">                        <input class="form-check-input" type="checkbox"                               id="editServiceDripfeed" name="dripfeed"                               @(Model.Dripfeed ? "checked" : "")>                        <label class="form-check-label" for="editServiceDripfeed">                            <i class="fas fa-tint me-1 text-info"></i> Drip-feed                        </label>                    </div>                </div>                <div class="col-md-4">                    <div class="form-check form-switch">                        <input class="form-check-input" type="checkbox"                               id="editServiceRefill" name="refill"                               @(Model.Refill ? "checked" : "")>                        <label class="form-check-label" for="editServiceRefill">                            <i class="fas fa-sync-alt me-1 text-success"></i> Refill                        </label>                    </div>                </div>                <div class="col-md-4">                    <div class="form-check form-switch">                        <input class="form-check-input" type="checkbox"                               id="editServiceCancel" name="cancel"                               @(Model.Cancel ? "checked" : "")>                        <label class="form-check-label" for="editServiceCancel">                            <i class="fas fa-ban me-1 text-danger"></i> Cancel                        </label>                    </div>                </div>            </div>        </div>        <!-- STATUS -->        <div class="mb-1">            <div class="form-check form-switch">                <input class="form-check-input" type="checkbox"                       id="editServiceIsActive" name="isActive"                       @(Model.IsActive ? "checked" : "")>                <label class="form-check-label fw-semibold" for="editServiceIsActive">Active</label>            </div>        </div>        <input type="hidden" id="editServiceId" name="id" value="@Model.Id">    </form></div><div class="modal-footer bg-body-tertiary p-3">    <button type="button"            class="btn btn-link text-decoration-none text-secondary"            data-bs-dismiss="modal">        Cancel    </button>    <button type="button"            id="btnSaveService"            class="btn btn-primary px-5 shadow-sm">        <span id="btnSaveServiceText">            <i class="fas fa-save me-2"></i>Save Changes        </span>        <span id="btnSaveServiceSpinner" class="d-none">            <span class="spinner-border spinner-border-sm me-2" role="status"></span>            Saving...        </span>    </button></div><script>(function () {    document.getElementById('btnSaveService').addEventListener('click', async function () {        const nameInput = document.getElementById('editServiceName');        if (!nameInput.value.trim()) {            nameInput.classList.add('is-invalid');            return;        }        nameInput.classList.remove('is-invalid');        const payload = {            id:               parseInt(document.getElementById('editServiceId').value),            name:             document.getElementById('editServiceName').value.trim(),            type:             document.getElementById('editServiceType').value.trim(),            rate:             parseFloat(document.getElementById('editServiceRate').value) || 0,            min:              parseInt(document.getElementById('editServiceMin').value) || 0,            max:              parseInt(document.getElementById('editServiceMax').value) || 0,            sortOrder:        parseInt(document.getElementById('editServiceSortOrder').value) || 0,            serviceCategoryId: document.getElementById('editServiceCategory').value || null,            providerId:       document.getElementById('editServiceProvider').value || null,            dripfeed:         document.getElementById('editServiceDripfeed').checked,            refill:           document.getElementById('editServiceRefill').checked,            cancel:           document.getElementById('editServiceCancel').checked,            isActive:         document.getElementById('editServiceIsActive').checked,        };        document.getElementById('btnSaveServiceText').classList.add('d-none');        document.getElementById('btnSaveServiceSpinner').classList.remove('d-none');        document.getElementById('btnSaveService').disabled = true;        try {            const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');            const response = await fetch('/admin/services/UpdateService', {                method: 'POST',                headers: {                    'Content-Type': 'application/json',                    'X-CSRF-TOKEN': token                },                body: JSON.stringify(payload)            });            const result = await response.json();            if (result.success) {                document.getElementById('editServiceAlert').innerHTML = `                    <div class="alert alert-success d-flex align-items-center gap-2 py-2">                        <i class="fas fa-check-circle"></i>                        Service updated successfully.                    </div>`;                if (typeof store !== 'undefined') {                    store.dispatch({ type: 'RELOAD_SERVICES' });                }                setTimeout(() => {                    bootstrap.Modal.getInstance(document.getElementById('dynamicModal'))?.hide();                }, 1200);            } else {                document.getElementById('editServiceAlert').innerHTML = `                    <div class="alert alert-danger d-flex align-items-center gap-2 py-2">                        <i class="fas fa-exclamation-circle"></i>                        ${result.message || 'An error occurred.'}                    </div>`;            }        } catch (err) {            document.getElementById('editServiceAlert').innerHTML = `                <div class="alert alert-danger py-2">                    <i class="fas fa-exclamation-circle me-2"></i>Connection error.                </div>`;        } finally {            document.getElementById('btnSaveServiceText').classList.remove('d-none');            document.getElementById('btnSaveServiceSpinner').classList.add('d-none');            document.getElementById('btnSaveService').disabled = false;        }    });})();</script>