@using AnatoliaSmmPanel.Areas.Admin.ViewModels.Services.Import
@model ImportViewModel

@section Styles {
    <link href="~/css/_data_table.css" rel="stylesheet" />
}

<style>
    .service-row {
        height: 60px !important;
        contain: strict;
    }

    #scrollArea {
        transform: translateZ(0);
        will-change: scroll-position;
        backface-visibility: hidden;
    }

</style>

<div class="wrapper" id="page-wrapper">

    <!-- ALERTS -->
    <div id="wrapper-alerts">
        <div class="wrapper-alerts"></div>
    </div>

    <div class="page">


        <div class="d-flex flex-column vh-100 bg-body-tertiary shadow-sm" style="padding: 10px;border-radius: 5px;">
    
            <header class="container-fluid py-4 border-bottom bg-body-tertiary">
                <div class="row align-items-center">
                    <div class="col-md-7">
                        <div class="d-flex flex-wrap gap-2">
                            <button id="add-service" class="btn btn-primary px-3">
                                <i class="fas fa-plus me-2"></i> Add Service
                            </button>
                            <button id="add-subscription" class="btn btn-outline-secondary px-3">Add Subscription</button>
                            <button id="create-category" class="btn btn-outline-secondary px-3"
                                    onclick="setModalSize(''); openDynamicModal('/admin/services/AddCategory')">
                                Create Category
                            </button>
                            <button id="import-button" class="btn btn-outline-info px-3" onclick="importbutton()">
                                Import
                            </button>
                        </div>
                    </div>
                    <div class="col-md-5">
                        <div class="input-group">
                            <span class="input-group-text bg-body border-end-0">
                                <i class="fas fa-search text-muted"></i>
                            </span>
                            <input type="text" id="searchInput" class="form-control border-start-0 py-2 bg-body" placeholder="Search for services...">
                            <select class="form-select border-start-0 bg-body" id="searchField" style="max-width: 150px;">
                                <option value="all">All Fields</option>
                                <option value="name">Service Name</option>
                                <option value="id">Service ID</option>
                                <option value="provider">Provider</option>
                                <option value="type">Service Type</option>
                            </select>
                        </div>
                    </div>
                </div>
            </header>

            <main class="flex-grow-1 d-flex flex-column overflow-hidden">
        
                <div class="border-bottom bg-body-tertiary" style="z-index: 10; padding-right: 17px;">
                    <table class="table table-sm mb-0 custom-table table-fixed">
                        <colgroup>
                            <col style="width: 50px;">
                            <col style="width: 80px;">
                            <col>
                            <col style="width: 150px;">
                            <col style="width: 150px;">
                            <col style="width: 100px;">
                            <col style="width: 80px;">
                            <col style="width: 80px;">
                            <col style="width: 110px;">
                            <col style="width: 120px;">
                        </colgroup>
                        <thead class="bg-body-secondary border-bottom">
                            <tr>
                                <th class="text-center">
                                    <input class="form-check-input" type="checkbox" id="checkAll">
                                </th>
                                <th>ID</th>
                                <th>Service Name</th>
                                <th>Type</th>
                                <th>Provider</th>
                                <th>Rate</th>
                                <th>Min</th>
                                <th>Max</th>
                                <th>Status</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                    </table>
                </div>

                <div id="scrollArea" class="flex-grow-1 overflow-auto">
                    <table class="table table-hover mb-0 custom-table table-fixed align-middle" id="serviceTable">
                        <colgroup>
                            <col style="width: 50px;">
                            <col style="width: 80px;">
                            <col>
                            <col style="width: 150px;">
                            <col style="width: 150px;">
                            <col style="width: 100px;">
                            <col style="width: 80px;">
                            <col style="width: 80px;">
                            <col style="width: 110px;">
                            <col style="width: 120px;">
                        </colgroup>
                        <tbody>
                        </tbody>
                    </table>
                </div>
            </main>

            <footer class="container-fluid py-3 border-top bg-body-tertiary">
                <div class="d-flex justify-content-between align-items-center">
                    <button type="button" class="btn btn-link btn-sm text-decoration-none text-secondary">
                        <i class="fas fa-trash-alt me-1"></i> Deleted Services
                    </button>
                    <span class="badge bg-secondary px-3 py-2" id="totalCount">Total: </span>
                </div>
            </footer>
        </div>

            
    </div>

</div>





<!-- Dinamik Modal İskeleti -->
<div class="modal fade" id="dynamicModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <!-- data-bs-theme mirasını bozmasın diye modal-content standart kalıyor -->
        <div class="modal-content border-0 shadow" id="dynamicModalBody">
            <div class="text-center p-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Yükleniyor...</span>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/redux/4.2.1/redux.min.js"></script>

    <script src="~/js/services/services.js"></script>

    <script src="~/js/services/servicemodal.js"></script>

    <script src="~/js/services/editservicemodal.js"></script>
    <script src="~/js/services/importservicesmodal.js"></script>
}