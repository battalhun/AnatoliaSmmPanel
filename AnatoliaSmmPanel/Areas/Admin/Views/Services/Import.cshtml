        @model AnatoliaSmmPanel.Areas.Admin.ViewModels.Services.Import.ImportViewModel

        @Html.AntiForgeryToken()

        <div class="modal-header bg-body-tertiary py-3">
            <h5 class="modal-title fw-bold" id="importServicesModalLabel">
                <i class="fas fa-file-import me-2 text-primary"></i>Import Services
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>

        <div class="modal-body p-4">

            <div class="row g-3 mb-4 align-items-end">
       
                <div class="col-md-4">
                    <label for="provider_id" class="form-label small fw-bold text-muted">
                        Select Provider
                    </label>
                    <form asp-action="Import" asp-controller="Services" method="post">
                    <select id="provider_id" name="provider_id" class="form-select bg-body">

                        @foreach (var provider in Model.ımportProviderViewModel)
                        {
                            <option value="@provider.Id"
                                        selected="@(provider.Id == Model.SelectedProviderId)">
                                @provider.Name
                            </option>
                   
                        }
                
                    </select>
           
                        <button type="submit" class="btn btn-outline-success">Success</button>
                    </form>
                </div>


                <div class="col-md-5 ms-auto">
                    <div class="input-group">
                        <span class="input-group-text bg-body border-end-0">
                            <i class="fas fa-search text-muted"></i>
                        </span>
                        <input type="text" id="importSearchInput" class="form-control border-start-0 bg-body" placeholder="Search categories or services...">
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                    <i class="fas fa-eye-slash me-1"></i> Hide Added
                </button>
                <div class="small text-muted fw-bold">
                    Rate Currency: <span class="text-primary">USD</span>
                </div>
            </div>

            <div class="border rounded overflow-hidden">
                <div class="d-flex justify-content-between align-items-center bg-body-secondary p-3 border-bottom fw-bold small text-uppercase">
                    <div class="d-flex align-items-center gap-3">
                        <input class="form-check-input mt-0" type="checkbox" id="selectAllCategories">
                        <span>Category / Service Name</span>
                    </div>
                    <div class="d-flex align-items-center gap-4">
                        <span class="me-5">Rate</span>
                        <span>Actions</span>
                    </div>
                </div>

                <div class="import-list-container bg-body" style="max-height: 500px; overflow-y: auto;">
            
          

                    <div class="bg-white border rounded-3 shadow-sm">

                        <!-- Header -->
                        <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom bg-light">
                            <div class="fw-semibold">Services</div>

                            <div class="d-flex align-items-center gap-2">
                                <button class="btn btn-sm btn-outline-secondary" >
                                    <i class="fas fa-sort-amount-down-alt"></i>
                                </button>
                                <span class="text-muted small">Rate, USD</span>
                            </div>
                        </div>

                        <!-- List -->
                        <div class="p-2" style="max-height: 550px; overflow-y: auto;">

                            @foreach (var categoryGroup in Model.ImportServicesViewModel.GroupBy(x => x.ImportExternalServicesCategoryViewModelId))
                            {
                                var firstItem = categoryGroup.First();

                                <div class="border rounded-3 mb-2">

                                    <!-- CATEGORY HEADER -->
                                    <div class="d-flex justify-content-between align-items-start p-3 border-bottom bg-body-tertiary">

                                        <!-- Left -->
                                        <div class="d-flex gap-3">

                                            <div class="form-check mt-1">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       id="select_all_@firstItem.ImportExternalServicesCategoryViewModelId">
                                            </div>

                                            <div>
                                                <div class="fw-semibold">
                                                    <label for="select_all_@firstItem.ImportExternalServicesCategoryViewModelId" class="mb-1">
                                                        @(firstItem.ImportExternalServicesCategoryViewModel.Name ?? "")
                                                    </label>
                                                </div>

                                                <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
                                                    <span class="text-muted small">Assigned</span>

                                                    <span class="badge bg-body text-body border">
                                                        CoinMarketCap
                                                    </span>

                                                    <button class="btn btn-sm btn-outline-secondary">
                                                        Change
                                                    </button>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Collapse Button -->
                                        <button class="btn btn-sm btn-outline-primary"
                                                data-bs-toggle="collapse"
                                                data-bs-target="#collapse_@firstItem.ImportExternalServicesCategoryViewModelId"
                                                aria-expanded="false"
                                                aria-controls="collapse_@firstItem.ImportExternalServicesCategoryViewModelId">

                                            Hide services (@categoryGroup.Count())

                                        </button>
                                    </div>

                                    <!-- SERVICES -->
                                    <div id="collapse_@firstItem.ImportExternalServicesCategoryViewModelId"
                                         class="list-group list-group-flush collapse">

                                        @foreach (var service in categoryGroup)
                                        {
                                            <div class="list-group-item py-3 d-flex justify-content-between align-items-start">

                                                <div class="d-flex gap-3">

                                                    <div class="form-check mt-1">
                                                <input class="form-check-input service-checkbox"
                                                               type="checkbox"
                                                                data-service-id="@service.Id"
                                                               id="import_@service.Id">
                                                    </div>

                                                    <div>
                                                        <label for="import_@service.Id"
                                                               class="fw-semibold d-block mb-1">

                                                            @service.Id - @service.Name

                                                            <span class="text-body-secondary fw-normal">
                                                                [Max: @service.Max]
                                                            </span>
                                                        </label>

                                                        <button class="btn btn-sm btn-outline-secondary mt-1">
                                                            Description
                                                        </button>
                                                    </div>

                                                </div>

                                                <span class="badge bg-primary fs-6 px-3 py-2">
                                                    @service.Rate USD
                                                </span>

                                            </div>
                                        }

                                    </div>
                                </div>
                            }

                        </div>
                    </div>
            
                </div>
            </div>

            <div class="mt-4 p-3 bg-light-subtle rounded border border-dashed">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" id="option-description" checked>
                    <label class="form-check-label fw-semibold" for="option-description">
                        Copy descriptions for default language
                    </label>
                </div>
            </div>

        </div>

<div class="modal-footer bg-body-tertiary p-3">

    <button type="button"
            class="btn btn-link text-decoration-none text-secondary px-4"
            data-bs-dismiss="modal">
        Close
    </button>

    <div class="d-flex align-items-center gap-4">

        <div class="small">
            <span class="text-muted">Selected:</span>
            <span class="badge bg-primary rounded-pill ms-1"
                  id="selectedCount">0</span>
        </div>

        <form id="importForm"
              asp-action="ImportSelectedServices"
              asp-controller="Services"
              method="post">

            @Html.AntiForgeryToken()

            <input type="hidden"
                   name="SelectedProviderId"
                   value="@Model.SelectedProviderId" />

            <div id="selectedServicesContainer"></div>

            <button type="button"
                    id="btnContinue"
                    class="btn btn-primary px-5 shadow-sm"
                    disabled>
                Continue
                <i class="fas fa-arrow-right ms-2"></i>
            </button>

        </form>

    </div>

</div>


        @section Scripts {
            <script src="~/js/services/importservicesmodal.js"></script>
        }